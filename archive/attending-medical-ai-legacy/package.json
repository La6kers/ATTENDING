{
  "name": "attending-medical-ai",
  "version": "0.1.0",
  "private": true,
  "description": "ATTENDING — AI-powered medical platform",
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --workspace=apps/backend",
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "setup": "node scripts/setup/init-db.js",
    "build": "npm run build --workspace=apps/frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
