# ============================================================
# ATTENDING AI - Development Environment Configuration
# .env.development.example
#
# Copy this file to .env.local and update values
# ============================================================

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="ATTENDING AI"
NEXT_PUBLIC_APP_VERSION="1.0.0-dev"
NEXT_PUBLIC_ENVIRONMENT="development"

# URLs
NEXTAUTH_URL=http://localhost:3000
PATIENT_PORTAL_URL=http://localhost:3001

# Database (SQLite for development)
DATABASE_PROVIDER=sqlite
DATABASE_URL="file:./dev.db"

# Authentication
NEXTAUTH_SECRET="development-secret-change-in-production"

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
SESSION_ENCRYPTION_KEY="fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210"

# Redis (optional for development - uses in-memory mock if not set)
# REDIS_URL=""

# Feature Flags
FEATURE_AI_DIFFERENTIAL_DIAGNOSIS=true
FEATURE_AI_DRUG_RECOMMENDATIONS=true
FEATURE_AI_LAB_ORDERING=true

# Health Check
HEALTH_CHECK_SECRET="dev-health-secret"
