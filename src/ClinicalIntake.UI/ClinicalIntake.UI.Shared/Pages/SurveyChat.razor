@page "/COMPASS"
@page "/survey/chat"
@page "/"
@rendermode InteractiveServer

@using ClinicalIntake.Application.Chat
@using ClinicalIntake.UI.Shared.Components
@using Microsoft.Extensions.Http
@using System.Text.Json
@using SharedKernel

<PageTitle>COMPASS</PageTitle>

<MudPaper Class="page-background rounded-0 pt-9" Height="100vh" Width="100vw">
    <MudContainer MaxWidth="MaxWidth.Large">

        <!-- dashboard -->
        <MudPaper Class="page-foreground rounded-xl d-flex flex-row" Height="90vh">

            <MudGrid Spacing="0">

                <!-- aside -->
                <MudItem md="4" Class="d-none d-md-flex flex-column flex-fill border-end">
                    <!-- header -->
                    <MudText Typo="Typo.h5" Align="Align.Center" Class="fw-bold py-4">ATTENDING AI</MudText>

                    <!-- emergency button -->
                    <MudButton Variant="Variant.Filled" Color="Color.Error" Class="ma-4 py-3 rounded-lg" OnClick="() => isEmergencyDialogVisible = true" Disabled="isConversationComplete">Emergency</MudButton>

                    <!-- assessment progress -->
                    <MudPaper Class="ma-4 pa-4 rounded-xl" Elevation="1">
                        <MudText Class="fw-bold pb-4 rounded-top-xl" Typo="Typo.body2" Align="Align.Center">Assessment Progress</MudText>
                        <MudStack Spacing="2" Class="ml-6">
                            @foreach(var stage in chatStages)
                            {
                                <MudPaper Elevation="0">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Disabled="chatStage < stage.Enum">@((int)stage.Enum)</MudChip>
                                    <MudText Class="ml-2" Typo="Typo.subtitle1" Color="Color.Dark" Inline=true>@stage.Value</MudText>
                                </MudPaper>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <!-- main -->
                <MudItem xs="12" md="8" Class="d-flex flex-column h-100">

                    <!-- header -->
                    <MudFab Color="Color.Error"
                            Size="Size.Small"
                            StartIcon="@Icons.Material.Outlined.CrisisAlert"
                            Class="position-absolute my-3 mx-4 d-flex d-md-none"
                            OnClick="() => isEmergencyDialogVisible = true"
                            DropShadow="false" />

                    <MudPaper Outlined="false" Class="d-flex flex-row">
                        <MudText Typo="Typo.h5" Align="Align.Center" Inline="true" Class="fw-bold py-4 border-bottom flex-fill">COMPASS</MudText>

                        <MudStack>
                            <MudText Typo="Typo.subtitle1" Align="Align.Start" Inline="true" Class="px-4">Clinic ID: @ClinicId</MudText>
                            <MudText Typo="Typo.subtitle1" Align="Align.Start" Inline="true" Class="px-4">MRN: @MRN</MudText>
                        </MudStack>
                    </MudPaper>
                    
                    <!-- chat -->
                    <MudPaper id="chatContainer" Elevation="0" Class="flex-fill mx-4 overflow-y-scroll">
                        @foreach(var chatMessage in chatMessages)
                        {
                            if(chatMessage.Role == ChatRole.User)
                            {
                                <MudChat ChatPosition="ChatBubblePosition.End">
                                    <MudChatBubble Color="Color.Primary" Variant="Variant.Filled">
                                        @chatMessage.Text
                                    </MudChatBubble>
                                </MudChat>
                            }
                            else
                            {
                                <MudChat ChatPosition="ChatBubblePosition.Start" Elevation="1">
                                    <MudAvatar Color="Color.Primary">
                                        <MudImage Src="/images/compass.svg" />
                                    </MudAvatar>
                                    <MudChatBubble Variant="Variant.Outlined">
                                        @chatMessage.Text
                                    </MudChatBubble>
                                </MudChat>
                            }
                        }
                    </MudPaper>

                    <!-- quick replies -->
                    @if(quickReplies.Any())
                    {
                        <MudPaper Class="d-flex ma-4" Elevation="0">
                            @foreach(var reply in quickReplies)
                            {
                                <MudButton Variant="Variant.Filled" Class="py-2 m-1 rounded-pill" OnClick="() => HandleQuickReply(reply)">
                                    @reply
                                </MudButton>
                            }
                        </MudPaper>
                    }

                    <!-- chat toolbar -->
                    <MudStack Row="true" Spacing=2 Class="mx-4">
                        <MudFab Color="Color.Primary"
                                Size="Size.Small"
                                StartIcon="@Icons.Material.Outlined.CameraAlt"
                                DropShadow="false"
                                Disabled=true
                                OnClick="openTakePictureDialog" />
                        <MudFab Color="Color.Success"
                                Size="Size.Small"
                                StartIcon="@Icons.Material.Outlined.MicNone"
                                DropShadow="false"
                                Disabled=true
                                OnClick="openRecordVoiceMessageDialog" />
                    </MudStack>

                    <!-- chat input -->
                    <MudPaper Class="d-flex ma-4" Elevation="0">
                        <MudTextField @bind-value="currentMessage"
                                      Placeholder="Describe your condition or symptoms..."
                                      Variant="Variant.Outlined"
                                      Class="flex-fill mr-2"
                                      OnKeyDown="@HandleKeyPress"
                                      Immediate="true"
                                      TextUpdateSuppression="false"
                                      Clearable="true"
                                      Disabled="isConversationComplete" />
                        <MudFab Color="Color.Primary"
                                StartIcon="@Icons.Material.Outlined.Send"
                                OnClick="SendMessage"
                                Disabled="isLoading || isConversationComplete || string.IsNullOrWhiteSpace(currentMessage)"
                                DropShadow="false">
                            Send
                        </MudFab>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>

    <!-- Emergency Dialog -->
    <MudDialog @bind-Visible="isEmergencyDialogVisible" Class="rounded-xl" Options="emergencyDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6" Align="Align.Center" Color="Color.Error" Class="fw-bold">🚨Emergency Help</MudText>
        </TitleContent>
        <DialogContent>
            <MudPaper Class="d-flex flex-column pb-3">
                <MudText Align="Align.Center" Class="mw-100 flex-shrink-1">If you're experiencing a life-threatening emergency, severe symptoms, or sudden onset of concerning symptoms, please seek immediate medical attention. Use the location finder to get GPS directions to nearby facilities.</MudText>
                <MudButton Variant="Variant.Outlined" Class="rounded-lg mt-3">
                    <MudStack Spacing="1" Class="flex-fill">
                        <MudText Typo="Typo.subtitle1" Align="Align.Left" Class="fw-bold">🚨 Call 911</MudText>
                        <MudText Typo="Typo.caption" Align="Align.Left">For severe injuries or life-threatening conditions</MudText>
                    </MudStack>
                </MudButton>
                <MudButton Variant="Variant.Outlined" Class="rounded-lg mt-3">
                    <MudStack Spacing="1" Class="flex-fill">
                        <MudText Typo="Typo.subtitle1" Align="Align.Left" Class="fw-bold">🏥 Find Emergency Rooms</MudText>
                        <MudText Typo="Typo.caption" Align="Align.Left">Locate nearby emergency departments with GPS</MudText>
                    </MudStack>
                </MudButton>
                <MudButton Variant="Variant.Outlined" Class="rounded-lg mt-3">
                    <MudStack Spacing="1" Class="flex-fill">
                        <MudText Typo="Typo.subtitle1" Align="Align.Left" Class="fw-bold">⚕️ Find Urgent Care</MudText>
                        <MudText Typo="Typo.caption" Align="Align.Left">Locate nearby urgent care centers with GPS</MudText>
                    </MudStack>
                </MudButton>
                <MudButton Variant="Variant.Outlined" Class="rounded-lg mt-3">
                    <MudStack Spacing="1" Class="flex-fill ">
                        <MudText Typo="Typo.subtitle1" Align="Align.Left" Class="fw-bold">📞 Nurse Hotline</MudText>
                        <MudText Typo="Typo.caption" Align="Align.Left">24/7 medical guidance</MudText>
                    </MudStack>
                </MudButton>
            </MudPaper>
        </DialogContent>
    </MudDialog>

    <MudDialog @bind-Visible="isRecordVoiceMessageDialogVisible">
        <TitleContent>
            <MudText Typo="Typo.h6" Align="Align.Center" Class="fw-bold">Record Voice Message</MudText>
        </TitleContent>
        <DialogContent>
            Voice message recording is not yet implemented. Please use text input to communicate your symptoms.
        </DialogContent>
    </MudDialog>
</MudPaper>

@code {
    [Inject]
    private ClinicalIntakeChatClient ClinicalIntakeChatClient { get; init; } = null!;

    [Inject]
    private IJSRuntime JSRuntime { get; init; } = null!;

    [Inject]
    private IDialogService DialogService { get; init; } = null!;

    private int ClinicId = int.Parse(Environment.GetEnvironmentVariable("CLINIC_ID") ?? throw new ArgumentNullException("CLINIC_ID environment variable has not been set."));
    private string MRN = string.Empty;
    private readonly List<ChatMessage> chatMessages = [];
    private string clinicalSummary = string.Empty;

    private ChatStage chatStage = ChatStage.ChiefComplaint;
    private readonly List<string> quickReplies = [];
    private string currentMessage = string.Empty;
    private bool isLoading = false;
    private bool isConversationComplete => chatStage >= ChatStage.Complete;
    private bool isEmergencyDialogVisible = false;
    private bool isTakingPictureDialogVisible = false;
    private bool isRecordVoiceMessageDialogVisible = false;
    private readonly DialogOptions emergencyDialogOptions = new()
    {
        MaxWidth = MaxWidth.ExtraSmall,
        FullWidth = true
    };
    private readonly DialogOptions takingPictureDialogOptions = new()
    {
        CloseButton = true,
        FullWidth = true,
        MaxWidth = MaxWidth.Medium,
        BackdropClick = false
    };

    private const string WELCOME_MESSAGE = "Welcome to Compass! I'm here to guide you through this process of documenting your health concerns and preparing a comprehensive report for your healthcare provider. Lets start with what is the main reason for your visit today?";
    private const string GOODBYE_MESSAGE = "Thank you for using Compass! A comprehensive report for your healthcare provider will be generated based on our conversation.";

    private readonly IEnumerable<(ChatStage Enum, string Value)> chatStages =
    [
        (Enum: ChatStage.ChiefComplaint, Value: "Chief Complaint"),
        (Enum: ChatStage.Symptoms, Value: "Symptoms"),
        (Enum: ChatStage.MedicalHistory, Value: "Medical History"),
        (Enum: ChatStage.CurrentMedications, Value: "Current Medication"),
        (Enum: ChatStage.ClinicalSummary, Value: "Clinical Summary")
    ];

    protected override void OnInitialized()
    {
        chatMessages.Add(new ChatMessage(ChatRole.Assistant) { Text = WELCOME_MESSAGE });
        MRN = MedicalRecordNumberGenerator.Generate(ClinicId);
    }

    private async Task ScrollToBottom() => await JSRuntime.InvokeVoidAsync("scrollToBottom", "chatContainer");

    private async Task SendMessage()
    {
        BeginLoading();
        ClearQuickReplies();
        AddUserMessage();
        StateHasChanged();

        await ScrollToBottom();

        try
        {
            var newAssistantChatMessage = AddAssistantMessage();

            var chatReplyStream = ClinicalIntakeChatClient.GetChatReply(chatMessages);
            if(chatReplyStream is null)
                return;

            var detectedStageString = string.Empty;
            ChatStage? detectedStage = null;
            await foreach(var chunk in chatReplyStream)
            {
                if(string.IsNullOrEmpty(chunk))
                    continue;

                detectedStageString += chunk;

                // Check if the stage name is present
                var stageEndIndex = detectedStageString.IndexOf(']');
                if(stageEndIndex != -1 && detectedStage is null)
                {
                    // Extract the stage name (e.g., "[CHIEF_COMPLAINT]")
                    var stageName = detectedStageString.Substring(1, stageEndIndex - 1); // Skip the '[' and exclude ']'
                    Console.WriteLine($"Detected stage name: {stageName}");
                    Console.WriteLine($"Detected stage string: {detectedStageString}");
                    // Try to parse the stage name into the ChatStage enum
                    if(Enum.TryParse<ChatStage>(stageName, true, out var parsedStage))
                    {
                        detectedStage = parsedStage;
                        chatStage = parsedStage; // Update the current chat stage
                        StateHasChanged();
                    }

                    // Remove the stage name from tempContent
                    newAssistantChatMessage.Text = detectedStageString[(stageEndIndex + 1)..];
                    continue;
                }

                // Append the remaining content to the assistant's message
                newAssistantChatMessage.Text += chunk;

                StateHasChanged();
                await ScrollToBottom();
            }

            if(string.IsNullOrEmpty(newAssistantChatMessage.Text))
                chatMessages.Remove(newAssistantChatMessage);

            await FetchQuickReplies();
            AddCompletionMessage();
            await FetchClinicalSummary();
            await TriggerEventChatSurveyCompleted();
        }
        catch(Exception exception)
        {
            HandleError(exception);
        }
        finally
        {
            EndLoading();
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    private void BeginLoading() => isLoading = true;
    private void EndLoading() => isLoading = false;

    private void ClearQuickReplies() => quickReplies.Clear();

    private async Task FetchQuickReplies()
    {
        quickReplies.Clear();
        if(chatStage >= ChatStage.Complete)
            return;

        try
        {
            var fetchedQuickReplies = await ClinicalIntakeChatClient.GetQuickReplies(chatMessages);
            if(fetchedQuickReplies is null)
                return;

            quickReplies.AddRange(fetchedQuickReplies);
        }
        catch(Exception exception)
        {
            AddErrorMessage($"Error fetching quick replies: {exception.Message}");
        }
    }

    private async Task FetchClinicalSummary()
    {
        if(chatStage < ChatStage.Complete)
            return;

        try
        {
            chatStage = ChatStage.ClinicalSummary;
            clinicalSummary = await ClinicalIntakeChatClient.GetClinicalSummary(chatMessages);
            if(clinicalSummary is null)
                return;

            chatMessages.Add(new ChatMessage(ChatRole.Assistant) { Text = clinicalSummary });
        }
        catch(Exception exception)
        {
            AddErrorMessage($"Error fetching clinical summary: {exception.Message}");
        }
    }

    private void AddUserMessage()
    {
        if(string.IsNullOrEmpty(currentMessage))
            return;

        chatMessages.Add(new(ChatRole.User) { Text = currentMessage });
        currentMessage = string.Empty;
    }

    private ChatMessage AddAssistantMessage()
    {
        var newAssistantMessage = new ChatMessage(ChatRole.Assistant);
        chatMessages.Add(newAssistantMessage);

        return newAssistantMessage;
    }

    private void AddErrorMessage(string message)
    {
        chatMessages.Add(new(ChatRole.Assistant) { Text = message });
        StateHasChanged();
    }

    private void AddCompletionMessage()
    {
        if(chatStage < ChatStage.Complete)
            return;

        chatStage = ChatStage.Complete;
        var completeConversationChatResponse = new ChatMessage(ChatRole.Assistant) { Text = GOODBYE_MESSAGE };
        chatMessages.Add(completeConversationChatResponse);
    }

    private async Task TriggerEventChatSurveyCompleted()
    {
        if(chatStage < ChatStage.Complete)
            return;

        var chatSurvey = new ChatSurvey(ClinicId)
        {
            MedicalRecordNumber = MRN,
            Summary = clinicalSummary
        };

        chatSurvey.Messages.AddRange(chatMessages);

        await ClinicalIntakeChatClient.TriggerEventChatSurveyCompleted(chatSurvey);
    }

    private async void onChatReplyStreamAppended(object? sender, (string AppendedString, string FullString) eventArgs, ChatMessage chatMessage)
    {
        if(chatMessage is null)
            return;

        chatMessage.Text += eventArgs.AppendedString ?? string.Empty;
        StateHasChanged();
        await ScrollToBottom();
    }

    private async Task HandleKeyPress(KeyboardEventArgs args)
    {
        if(args.Key == "Enter" && !args.ShiftKey)
            await SendMessage();
    }

    private async Task HandleQuickReply(string reply)
    {
        currentMessage = reply;
        await SendMessage();
    }

    private void HandleError(Exception exception)
    {
        AddErrorMessage($"Error: {exception.Message}");
    }

    private void openRecordVoiceMessageDialog() => isRecordVoiceMessageDialogVisible = true;
    private void closeRecordVoiceMessageDialog() => isRecordVoiceMessageDialogVisible = false;

    private Task openTakePictureDialog() => DialogService.ShowAsync<TakePicturesDialog>(null, takingPictureDialogOptions);
}