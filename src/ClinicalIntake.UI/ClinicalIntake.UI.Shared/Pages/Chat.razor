@page "/chat"
@layout EmptyLayout
@rendermode InteractiveServer

@using Microsoft.Extensions.Http
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JSRuntime

<PageTitle>COMPASS</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudPaper Class="pa-4" Style="height: calc(100vh - 150px); display: flex; flex-direction: column;">
        <div Class="d-flex align-center justify-center mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Explore" Style="font-size: 2rem; margin-right: 8px;" Color="Color.Primary" />
            <MudText Typo="Typo.h5" Align="Align.Center">COMPASS</MudText>
        </div>
        
        <MudPaper Class="flex-grow-1 overflow-auto pa-4" Elevation="0" id="chatContainer">
            <div>
                @foreach (var message in chatMessages)
                {
                    <div class="mb-3">
                        <MudPaper Class="pa-3" Elevation="1" Style="@(message.IsUser ? "background-color: #f0f4f8" : "background-color: #ffffff")">
                            <MudText Typo="Typo.body1">
                                <MudText Typo="Typo.subtitle2" Color="@(message.IsUser ? Color.Primary : Color.Secondary)">
                                    @(message.IsUser ? "You" : "Assistant")
                                </MudText>
                                @message.Text
                            </MudText>
                        </MudPaper>
                    </div>
                }
                <div id="scrollTarget"></div>
            </div>
        </MudPaper>
        
        <MudPaper Class="d-flex align-center mt-4" Elevation="0">
            <MudTextField @bind-value="currentMessage" 
                         Placeholder="Describe your condition or symptoms..." 
                         Variant="Variant.Outlined" 
                         Class="flex-grow-1 mr-2"
                         OnKeyDown="@HandleKeyPress" 
                         Immediate="true"
                         TextUpdateSuppression="false"
                         Clearable="true" />
            <MudButton Color="Color.Primary" 
                      Variant="Variant.Filled"
                      OnClick="SendMessage"
                      Disabled="isLoading">
                Send
            </MudButton>
        </MudPaper>
    </MudPaper>
</MudContainer>

@code {
    private string currentMessage = string.Empty;
    private List<ChatMessage> chatMessages = [];
    private HttpClient Http => HttpClientFactory.CreateClient("ClinicalIntakeApi");
    private bool isLoading = false;

    protected override void OnInitialized()
    {
        chatMessages.Add(new ChatMessage { 
            Text = "Welcome to Compass! I'm here to guide you through this process of documenting your health concerns and preparing a comprehensive report for your healthcare provider.", 
            IsUser = false 
        });
    }

    private async Task ScrollToBottom()
    {
        await JSRuntime.InvokeVoidAsync("scrollToBottom", "chatContainer");
    }

    private async Task SendMessage()
    {
        if (!string.IsNullOrWhiteSpace(currentMessage))
        {
            isLoading = true; // Disable the button
            StateHasChanged();

            // Add user message
            var currentUserChatMessage = new ChatMessage() { 
                Text = currentMessage, 
                IsUser = true
            };

            chatMessages.Add(currentUserChatMessage);

            currentMessage = "";
            StateHasChanged();

            await ScrollToBottom();

            try
            {
                var content = chatMessages.Select(msg => new sendChatMessageDto(msg.IsUser ? 2 : 3, msg.Text));
                var request = new HttpRequestMessage(HttpMethod.Post, "api/chat/send")
                {
                    Content = JsonContent.Create(content)
                };

                using var httpResponse = await Http.PostAsync("api/chat/send", JsonContent.Create(content));
                if (httpResponse.IsSuccessStatusCode)
                {

                    var newChatResponse = new ChatMessage() { IsUser = false };
                    chatMessages.Add(newChatResponse); 
                    StateHasChanged();

                    var stream = await httpResponse.Content.ReadAsStreamAsync();
                    using var reader = new StreamReader(stream);
                    while(!reader.EndOfStream)
                    {
                        var textChunksJson = reader.ReadLine();
                        if(string.IsNullOrEmpty(textChunksJson))
                            continue;

                        // Check if the line contains metadata
                        // \"IsComplete\":true}
                        if (textChunksJson.Contains("\"IsComplete\":true"))
                        {
                            var completeConversationChatResponse = new ChatMessage() { 
                                Text = "Conversation Completed",
                                IsUser = false };
                            chatMessages.Add(completeConversationChatResponse);
                            StateHasChanged();

                            break;
                        }

                        var textChunks = System.Text.Json.JsonSerializer.Deserialize<List<string?>>(textChunksJson) ?? [];
                        foreach (var textChunk in textChunks)
                            if (!string.IsNullOrEmpty(textChunk))
                            {
                                newChatResponse.Text += textChunk;
                                StateHasChanged();
                                await ScrollToBottom();
                            }
                    }
                }
                else
                {
                    var newChatResponse = new ChatMessage() 
                    { 
                        Text = "An error occurred while getting a reply.",
                        IsUser = false 
                    };

                    chatMessages.Add(newChatResponse);
                    StateHasChanged();
                }
            }
            catch (Exception exception)
            {
                var chatResponse = new ChatMessage() 
                { 
                    Text = $"Error: {exception.Message}",
                    IsUser = false 
                };
                chatMessages.Add(chatResponse);
                StateHasChanged();
            }
            finally
            {
                isLoading = false;
                StateHasChanged();
            }

            await ScrollToBottom(); 
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" && !args.ShiftKey)
            await SendMessage();
    }

    private record sendChatMessageDto(int role, string content);

    private class ChatMessage
    {
        public string Text { get; set; } = "";
        public bool IsUser { get; set; }
    }

    private class StreamingChatReply
    {
        public string Text { get; set; } = "";
    }
}
