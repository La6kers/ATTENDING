@page "/chat"
@layout EmptyLayout
@rendermode InteractiveServer

@using ClinicalIntake.Application.Chat
@using Microsoft.Extensions.Http
@using System.Text.Json
@using SharedKernel

@inject ClinicalIntakeChatClient ClinicalIntakeChatClient
@inject IJSRuntime JSRuntime

<PageTitle>COMPASS</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudPaper Class="pa-4" Style="height: calc(100vh - 150px); display: flex; flex-direction: column;">
        <div Class="d-flex align-center justify-center mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Explore" Style="font-size: 2rem; margin-right: 8px;" Color="Color.Primary" />
            <MudText Typo="Typo.h5" Align="Align.Center">COMPASS</MudText>
        </div>
        
        <MudPaper Class="flex-grow-1 overflow-auto pa-4" Elevation="0" id="chatContainer">
            <div>
                @foreach (var message in chatMessages)
                {
                    <div class="mb-3">
                        <MudPaper Class="pa-3" Elevation="1" Style="@(message.Role == ChatRole.User ? "background-color: #f0f4f8" : "background-color: #ffffff")">
                            <MudText Typo="Typo.body1">
                                <MudText Typo="Typo.subtitle2" Color="@(message.Role == ChatRole.User ? Color.Primary : Color.Secondary)">
                                    @(message.Role == ChatRole.User ? "You" : "Assistant")
                                </MudText>
                                @message.Content
                            </MudText>
                        </MudPaper>
                    </div>
                }
            </div>
        </MudPaper>
        
        <MudPaper Class="d-flex align-center mt-4" Elevation="0">
            <MudTextField @bind-value="currentMessage" 
                         Placeholder="Describe your condition or symptoms..." 
                         Variant="Variant.Outlined" 
                         Class="flex-grow-1 mr-2"
                         OnKeyDown="@HandleKeyPress" 
                         Immediate="true"
                         TextUpdateSuppression="false"
                         Clearable="true" 
                         Disabled="isConversationComplete"/>
            <MudButton Color="Color.Primary" 
                      Variant="Variant.Filled"
                      OnClick="SendMessage"
                      Disabled="isLoading || isConversationComplete || string.IsNullOrWhiteSpace(currentMessage)">
                Send
            </MudButton>
        </MudPaper>

        @if (quickReplies.Any())
        {
            <MudPaper Class="d-flex flex-wrap mt-2" Elevation="0">
                @foreach (var reply in quickReplies)
                {
                    <MudButton Variant="Variant.Outlined" Class="m-1" OnClick="() => HandleQuickReply(reply)">
                        @reply
                    </MudButton>
                }
            </MudPaper>
        }
    </MudPaper>
</MudContainer>

@code {
    private readonly List<ChatMessage> chatMessages = [];
    private readonly List<string> quickReplies = [];
    private string currentMessage = string.Empty;
    private ChatStage chatStage = ChatStage.ChiefComplaint;
    private bool isLoading = false;
    private bool isConversationComplete = false;

    private const string WELCOME_MESSAGE = "Welcome to Compass! I'm here to guide you through this process of documenting your health concerns and preparing a comprehensive report for your healthcare provider.";
    private const string GOODBYE_MESSAGE = "Thank you for using Compass! A comprehensive report for your healthcare provider will be generated based on our conversation.";

    protected override void OnInitialized()
    {
        chatMessages.Add(new ChatMessage(ChatRole.Assistant, WELCOME_MESSAGE));
    }

    private async Task ScrollToBottom() => await JSRuntime.InvokeVoidAsync("scrollToBottom", "chatContainer");

    private async Task SendMessage()
    {
        // set loading state true
        // clear quick replies
        // add user message to chat
        // scroll to bottom
        // get chat reply
        // handle chat stage completion
        // handle conversation completion
        // fetch quick replies

        // set loading state false


        BeginLoading();
        ClearQuickReplies();
        AddUserMessage();
        StateHasChanged();

        await ScrollToBottom();

        try
        {
            using var chatReplyStream = AddAssistantMessage();

            var isChatStageComplete = await ClinicalIntakeChatClient.GetChatReply(chatMessages, chatStage, chatReplyStream);

            if (isChatStageComplete)
            {
                await OnChatStageComplete(chatReplyStream);
                return;
            }

            await FetchQuickReplies();
        }
        catch (Exception exception)
        {
            HandleError(exception);
        }
        finally
        {
            EndLoading();
            StateHasChanged();
        }
    }

    private void BeginLoading() => isLoading = true;
    private void EndLoading() => isLoading = false;

    private void ClearQuickReplies() => quickReplies.Clear();

    private async Task OnChatStageComplete(ObservableStringBuilder chatReplyStream)
    {
        chatStage = await ClinicalIntakeChatClient.HandleChatStageCompletion(chatMessages, chatStage, chatReplyStream);

        if (chatStage == ChatStage.ClinicalSummary)
        {
            quickReplies.Clear();
            isConversationComplete = true;
            AddCompletionMessage();
            await FetchClinicalSummary();
            return;
        }
    }

    private async Task FetchQuickReplies()
    {
        quickReplies.Clear();

        try
        {
            var fetchedQuickReplies = await ClinicalIntakeChatClient.GetQuickReplies(chatMessages);
            if(fetchedQuickReplies is null)
                return;

            quickReplies.AddRange(fetchedQuickReplies);
        }
        catch(Exception exception)
        {
            AddErrorMessage($"Error fetching quick replies: {exception.Message}");
        }
    }

    private async Task FetchClinicalSummary()
    {
        try
        {
            var clinicalSummary = await ClinicalIntakeChatClient.GetClinicalSummary(chatMessages);
            if(clinicalSummary is null)
                return;

            chatMessages.Add(new ChatMessage(ChatRole.Assistant, clinicalSummary));
        }
        catch(Exception exception)
        {
            AddErrorMessage($"Error fetching clinical summary: {exception.Message}");
        }
    }

    private void AddUserMessage()
    {
        if(string.IsNullOrEmpty(currentMessage))
            return;

        chatMessages.Add(new (ChatRole.User, currentMessage));
        currentMessage = string.Empty;
    }

    private ObservableStringBuilder AddAssistantMessage()
    {
        var newAssistantMessage = new ChatMessage(ChatRole.Assistant, string.Empty);
        chatMessages.Add(newAssistantMessage);
        ObservableStringBuilder observableStringBuilder = new();
        observableStringBuilder.Appended += (sender, eventArgs) => onChatReplyStreamAppended(sender, eventArgs, newAssistantMessage);
        return observableStringBuilder;
    }

    private void AddErrorMessage(string message)
    {
        chatMessages.Add(new(ChatRole.Assistant, message));
        StateHasChanged();
    }

    private void AddCompletionMessage()
    {
        var completeConversationChatResponse = new ChatMessage(ChatRole.Assistant, GOODBYE_MESSAGE);
        chatMessages.Add(completeConversationChatResponse);
    }

    private void onChatReplyStreamAppended(object? sender, (string AppendedString, string FullString) eventArgs, ChatMessage chatMessage)
    {
        if(chatMessage is null)
            return;

        chatMessage.Content = eventArgs.FullString ?? string.Empty;
        StateHasChanged();
    }

    private async Task HandleKeyPress(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" && !args.ShiftKey)
            await SendMessage();
    }

    private async Task HandleQuickReply(string reply)
    {
        currentMessage = reply;
        await SendMessage();
    }

    private void HandleError(Exception exception)
    {
        AddErrorMessage($"Error: {exception.Message}");
    }
}
