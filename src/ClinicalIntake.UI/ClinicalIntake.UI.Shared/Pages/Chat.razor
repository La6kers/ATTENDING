@page "/chat"
@layout EmptyLayout
@rendermode InteractiveServer

@using Microsoft.Extensions.Http
@using System.Text.Json
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JSRuntime

<PageTitle>COMPASS</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudPaper Class="pa-4" Style="height: calc(100vh - 150px); display: flex; flex-direction: column;">
        <div Class="d-flex align-center justify-center mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Explore" Style="font-size: 2rem; margin-right: 8px;" Color="Color.Primary" />
            <MudText Typo="Typo.h5" Align="Align.Center">COMPASS</MudText>
        </div>
        
        <MudPaper Class="flex-grow-1 overflow-auto pa-4" Elevation="0" id="chatContainer">
            <div>
                @foreach (var message in chatMessages)
                {
                    <div class="mb-3">
                        <MudPaper Class="pa-3" Elevation="1" Style="@(message.IsUser ? "background-color: #f0f4f8" : "background-color: #ffffff")">
                            <MudText Typo="Typo.body1">
                                <MudText Typo="Typo.subtitle2" Color="@(message.IsUser ? Color.Primary : Color.Secondary)">
                                    @(message.IsUser ? "You" : "Assistant")
                                </MudText>
                                @message.Text
                            </MudText>
                        </MudPaper>
                    </div>
                }
                <div id="scrollTarget"></div>
            </div>
        </MudPaper>
        
        <MudPaper Class="d-flex align-center mt-4" Elevation="0">
            <MudTextField @bind-value="currentMessage" 
                         Placeholder="Describe your condition or symptoms..." 
                         Variant="Variant.Outlined" 
                         Class="flex-grow-1 mr-2"
                         OnKeyDown="@HandleKeyPress" 
                         Immediate="true"
                         TextUpdateSuppression="false"
                         Clearable="true" 
                         Disabled="isConversationComplete"/>
            <MudButton Color="Color.Primary" 
                      Variant="Variant.Filled"
                      OnClick="SendMessage"
                      Disabled="isLoading || isConversationComplete">
                Send
            </MudButton>
        </MudPaper>

        @if (quickReplies.Any())
        {
            <MudPaper Class="d-flex flex-wrap mt-2" Elevation="0">
                @foreach (var reply in quickReplies)
                {
                    <MudButton Variant="Variant.Outlined" Class="m-1" OnClick="() => HandleQuickReply(reply)">
                        @reply
                    </MudButton>
                }
            </MudPaper>
        }
    </MudPaper>
</MudContainer>

@code {
    private string currentMessage = string.Empty;
    private List<ChatMessage> chatMessages = [];
    private HttpClient Http => HttpClientFactory.CreateClient("ClinicalIntakeApi");
    private bool isLoading = false;
    private bool isConversationComplete = false;
    private const string CONVERSATION_COMPLETED_MARKER = "[FINISH]";
    private const string WELCOME_MESSAGE = "Welcome to Compass! I'm here to guide you through this process of documenting your health concerns and preparing a comprehensive report for your healthcare provider.";
    private const string GOODBYE_MESSAGE = "Thank you for using Compass! A comprehensive report for your healthcare provider will be generated based on our conversation.";
    private List<string> quickReplies = new();


    protected override void OnInitialized()
    {
        chatMessages.Add(new ChatMessage { 
            Text = WELCOME_MESSAGE,
            IsUser = false 
        });
    }

    private async Task ScrollToBottom()
    {
        await JSRuntime.InvokeVoidAsync("scrollToBottom", "chatContainer");
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(currentMessage)) return;

        isLoading = true;
        StateHasChanged();

        AddUserMessage();
        await ScrollToBottom();

        try
        {
            var content = PrepareChatContent();
            var response = await SendChatRequest(content);
            await HandleChatResponse(response);
        }
        catch (Exception exception)
        {
            HandleError(exception);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }

        await ScrollToBottom();
    }

    private IEnumerable<sendChatMessageDto> PrepareChatContent()
    {
        return chatMessages.Select(msg => new sendChatMessageDto(msg.IsUser ? 2 : 3, msg.Text));
    }

    private async Task<HttpResponseMessage> SendChatRequest(IEnumerable<sendChatMessageDto> content)
    {
        return await Http.PostAsync("api/chat/send", JsonContent.Create(content));
    }

    private async Task HandleChatResponse(HttpResponseMessage response)
    {
        if (response.IsSuccessStatusCode)
        {
            var newChatResponse = new ChatMessage { IsUser = false };
            chatMessages.Add(newChatResponse);
            StateHasChanged();
            await ScrollToBottom();

            using var stream = await response.Content.ReadAsStreamAsync();
            await ProcessStreamingResponse(stream, newChatResponse);
        }
        else
        {
            AddErrorMessage("An error occurred while getting a reply.");
        }
    }

    private async Task ProcessStreamingResponse(Stream stream, ChatMessage newChatResponse)
    {
        using var reader = new StreamReader(stream);
        while (!reader.EndOfStream)
        {
            var textChunksJson = await reader.ReadLineAsync();
            if (string.IsNullOrEmpty(textChunksJson)) continue;

            var textChunks = JsonSerializer.Deserialize<List<string?>>(textChunksJson) ?? [];
            foreach (var textChunk in textChunks)
                if (!string.IsNullOrEmpty(textChunk))
                {
                    newChatResponse.Text += textChunk;
                    StateHasChanged();
                    await ScrollToBottom();
                }

            if (newChatResponse.Text.Contains(CONVERSATION_COMPLETED_MARKER))
            {
                quickReplies.Clear();
                isConversationComplete = true;
                chatMessages.Remove(newChatResponse);
                AddCompletionMessage();
                StateHasChanged();
                await ScrollToBottom();

                await FetchClinicalSummary();
                return;
            }
        }

        await FetchQuickReplies();
    }

    private async Task FetchQuickReplies()
    {
        try
        {
            var content = PrepareChatContent();
            var response = await Http.PostAsync("api/chat/getquickreplies", JsonContent.Create(content));

            if (response.IsSuccessStatusCode)
            {
                var quickRepliesResponse = await response.Content.ReadFromJsonAsync<List<string>>();
                if (quickRepliesResponse != null)
                    quickReplies = quickRepliesResponse;
            }
            else
                quickReplies.Clear();
        }
        catch (Exception ex)
        {
            quickReplies.Clear();
            AddErrorMessage($"Error fetching quick replies: {ex.Message}");
        }
        finally
        {
            StateHasChanged();
        }
    }

    private async Task HandleQuickReply(string reply)
    {
        quickReplies.Clear();
        StateHasChanged();
        
        currentMessage = reply;
        await SendMessage();
    }

    private async Task FetchClinicalSummary()
    {
        try
        {
            var content = PrepareChatContent();
            var response = await Http.PostAsync("api/chat/getclinicalsummary", JsonContent.Create(content));

            if (response.IsSuccessStatusCode)
            {
                var summary = await response.Content.ReadAsStringAsync();
                AddSummaryMessage(summary);
            }
            else
                AddErrorMessage("Failed to retrieve clinical summary.");
        }
        catch (Exception ex)
        {
            AddErrorMessage($"Error: {ex.Message}");
        }
        finally
        {
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    private void AddUserMessage()
    {
        var currentUserChatMessage = new ChatMessage
        {
            Text = currentMessage,
            IsUser = true
        };

        chatMessages.Add(currentUserChatMessage);
        currentMessage = string.Empty;
        StateHasChanged();
    }

    private void AddErrorMessage(string message)
    {
        var chatResponse = new ChatMessage
        {
            Text = message,
            IsUser = false
        };

        chatMessages.Add(chatResponse);
        StateHasChanged();
    }

    private void AddCompletionMessage()
    {
        var completeConversationChatResponse = new ChatMessage
        {
            Text = GOODBYE_MESSAGE,
            IsUser = false
        };

        chatMessages.Add(completeConversationChatResponse);
    }

    private void AddSummaryMessage(string summary)
    {
        var summaryMessage = new ChatMessage
        {
            Text = $"Clinical Summary:\n{summary}",
            IsUser = false
        };

        chatMessages.Add(summaryMessage);
        StateHasChanged();
    }

    private async Task HandleKeyPress(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" && !args.ShiftKey)
            await SendMessage();
    }

    private void HandleError(Exception exception)
    {
        AddErrorMessage($"Error: {exception.Message}");
    }

    private record sendChatMessageDto(int role, string content);

    private class ChatMessage
    {
        public string Text { get; set; } = "";
        public bool IsUser { get; set; }
    }

    private class StreamingChatReply
    {
        public string Text { get; set; } = "";
    }
}
