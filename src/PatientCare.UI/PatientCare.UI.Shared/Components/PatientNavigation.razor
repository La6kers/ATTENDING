@using MudBlazor

<MudPaper Elevation="2" Class="d-flex flex-fill flex-column">
    <MudStack Spacing="1" Row="true" Justify="Justify.SpaceEvenly" AlignItems="AlignItems.Stretch" StretchItems="StretchItems.All">
        <MudButton FullWidth="true" Disabled="true">
            <MudText Typo="Typo.subtitle1" Align="Align.Center">Pre-Visit Summary</MudText>
        </MudButton>
        <MudButton FullWidth="true" Disabled="true">
            <MudText Typo="Typo.subtitle1" Align="Align.Center">AI Dirrefential</MudText>
        </MudButton>
        <MudButton FullWidth="true" Disabled="true">
            <MudText Typo="Typo.subtitle1" Align="Align.Center">Treatment Options</MudText>
        </MudButton>
        <MudButton FullWidth="true" Disabled="true">
            <MudText Typo="Typo.subtitle1" Align="Align.Center">Documentation</MudText>
        </MudButton>
        <MudButton FullWidth="true" Disabled="true">
            <MudText Typo="Typo.subtitle1" Align="Align.Center">Patient History</MudText>
        </MudButton>
    </MudStack>
</MudPaper>

