@using MudBlazor


<MudPaper Elevation="2" Class="d-flex flex-fill flex-column">
    <MudStack Spacing="1" Row="true" Justify="Justify.SpaceEvenly" AlignItems="AlignItems.Stretch" StretchItems="StretchItems.All">
        <MudButton FullWidth="true" Disabled="true">
            <MudText Typo="Typo.subtitle1" Align="Align.Center">🧪 Order Labs</MudText>
        </MudButton>
        <MudButton FullWidth="true" Disabled="true">
            <MudText Typo="Typo.subtitle1" Align="Align.Center">💊 E-Prescribe</MudText>
        </MudButton>
        <MudButton FullWidth="true" Disabled="true">
            <MudText Typo="Typo.subtitle1" Align="Align.Center">👥 Refer</MudText>
        </MudButton>
        <MudButton FullWidth="true" Disabled="true">
            <MudText Typo="Typo.subtitle1" Align="Align.Center">🔍 Order Imaging</MudText>
        </MudButton>
        <MudButton FullWidth="true" Disabled="true">
            <MudText Typo="Typo.subtitle1" Align="Align.Center">📅 Schedule Follow-up</MudText>
        </MudButton>
        <MudButton FullWidth="true" Disabled="true">
            <MudText Typo="Typo.subtitle1" Align="Align.Center">📚 Patient Education</MudText>
        </MudButton>
    </MudStack>
</MudPaper>

