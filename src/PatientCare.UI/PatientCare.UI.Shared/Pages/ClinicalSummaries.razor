@page "/"
@page "/provider-portal/ClinicalSummaries"

@using PatientCare.Application.Diagnostics
@using PatientCare.UI.Shared.Services
@using MudBlazor
@inject NavigationManager Navigation

<PageTitle>Provider Portal</PageTitle>

<MudStack Spacing="3" Class="m-4">
    @* clinic *@
    <MudText Typo="Typo.h4" Align="Align.Center">Clinic Id: @_clinicId</MudText>

    @* provider *@
    <MudPaper Elevation="2">
        <MudSelect T="string"
                   @bind-Value="_selectedProvider"
                   Label="Providers"
                   Placeholder="Choose Providers">
            @foreach(var provider in _providers)
            {
                <MudSelectItem Value="@provider">@provider</MudSelectItem>
            }
        </MudSelect>
    </MudPaper>

    @* navigation *@
    <MudPaper Elevation="2" Class="d-flex flex-fill flex-column">
        <MudStack Spacing="1" Row="true" Justify="Justify.SpaceEvenly" AlignItems="AlignItems.Stretch" StretchItems="StretchItems.All">
            <MudButton FullWidth="true" Disabled="true">
                <MudText Typo="Typo.subtitle1" Align="Align.Center">🧪 Order Labs</MudText>
            </MudButton>
            <MudButton FullWidth="true" Disabled="true">
                <MudText Typo="Typo.subtitle1" Align="Align.Center">💊 E-Prescribe</MudText>
            </MudButton>
            <MudButton FullWidth="true" Disabled="true">
                <MudText Typo="Typo.subtitle1" Align="Align.Center">👥 Refer</MudText>
            </MudButton>
            <MudButton FullWidth="true" Disabled="true">
                <MudText Typo="Typo.subtitle1" Align="Align.Center">🔍 Order Imaging</MudText>
            </MudButton>
            <MudButton FullWidth="true" Disabled="true">
                <MudText Typo="Typo.subtitle1" Align="Align.Center">📅 Schedule Follow-up</MudText>
            </MudButton>
            <MudButton FullWidth="true" Disabled="true">
                <MudText Typo="Typo.subtitle1" Align="Align.Center">📚 Patient Education</MudText>
            </MudButton>
        </MudStack>    
    </MudPaper>

    @* summaries *@
    <MudPaper Elevation="2">
        <MudTable T="ClinicalSummaryDto"
                  Items="@clinicalSummaries"
                  Hover="true"
                  Striped="true"
                  Filter="new Func<ClinicalSummaryDto, bool>(FilterFunction)"
                  RowClick="OnRowClick">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Clinical Summaries</MudText>
                <MudSpacer />
                <MudTextField T="string"
                              @bind-Value="searchString"
                              Placeholder="Search"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium"
                              Class="mt-0" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Medical Record Number</MudTh>
                <MudTh>First Name</MudTh>
                <MudTh>Last Name</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Medical Record Number">@context.MedicalRecordNumber</MudTd>
                <MudTd DataLabel="First Name">@context.FirstName</MudTd>
                <MudTd DataLabel="Last Name">@context.LastName</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private readonly int _clinicId = 9001;
    private readonly List<string> _providers = [];
    private readonly List<ClinicalSummaryDto> clinicalSummaries = [];
    private string searchString = string.Empty;

    private string _selectedProvider = string.Empty;

    protected override void OnInitialized()
    {
        _providers.Add("Bob the Builder");
        _providers.Add("Darth Vader");
        _providers.Add("Dora the Explorer");

        clinicalSummaries.Add(new("123456", "Alice", "Anderson"));
        clinicalSummaries.Add(new("111222", "Brian", "Baker"));
        clinicalSummaries.Add(new("654321", "Carla", "Cruz"));
    }

    private bool FilterFunction(ClinicalSummaryDto clinicalSummary)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (clinicalSummary.MedicalRecordNumber.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    private void OnRowClick(TableRowClickEventArgs<ClinicalSummaryDto> args)
    {
        // Navigate to detail page; pass MRN as query string (adjust detail page to read it)
        Navigation.NavigateTo($"/provider-portal/ClinicalSummary?mrn={args.Item.MedicalRecordNumber}");
    }

    public record ClinicalSummaryDto(
        string MedicalRecordNumber,
        string FirstName,
        string LastName
    );
}
