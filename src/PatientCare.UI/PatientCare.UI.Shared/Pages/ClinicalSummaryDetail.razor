@page "/provider-portal/ClinicalSummary"

@using PatientCare.Application.Diagnostics
@using PatientCare.UI.Shared.Services
@using MudBlazor

<PageTitle>Provider Portal</PageTitle>

<MudStack Spacing="3" Class="m-4">
    @* clinic *@
    <MudText Typo="Typo.h4" Align="Align.Center">Clinic Id: @_clinicalSummary.ClinicId</MudText>

    @* navigation *@
    <MudPaper Elevation="2" Class="container justify-content-center">
        <MudButtonGroup Color="Color.Primary" Variant="Variant.Text" Class="row justify-content-evenly">
            <MudButton Class="col">
                <MudText Typo="Typo.subtitle1" Align="Align.Center">🧪 Order Labs</MudText>
            </MudButton>
            <MudButton Class="col">
                <MudText Typo="Typo.subtitle1" Align="Align.Center">💊 E-Prescribe</MudText>
            </MudButton>
            <MudButton Class="col">
                <MudText Typo="Typo.subtitle1" Align="Align.Center">👥 Refer</MudText>
            </MudButton>
            <MudButton Class="col">
                <MudText Typo="Typo.subtitle1" Align="Align.Center">🔍 Order Imaging</MudText>
            </MudButton>
            <MudButton Class="col">
                <MudText Typo="Typo.subtitle1" Align="Align.Center">📅 Schedule Follow-up</MudText>
            </MudButton>
            <MudButton Class="col">
                <MudText Typo="Typo.subtitle1" Align="Align.Center">📚 Patient Education</MudText>
            </MudButton>
        </MudButtonGroup>
    </MudPaper>

    @* summary details *@
    <MudPaper Elevation="3">
        <MudStack Class="m-3">
            <MudText Typo="Typo.caption">🤖 AI-Generated Clinical Summary</MudText>
            
            @* vital signs *@
            <MudPaper Elevation="3">
                <MudFab Label="📊" />
                <MudText Typo="Typo.h6">Vital Signs</MudText>
                @* blood preasure *@
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.caption">BP: @_clinicalSummary.VitalSigns.BloodPressureDiastolic/@_clinicalSummary.VitalSigns.BloodPressureSystolic</MudText>
                    </MudCardContent>
                </MudCard>

                @* heart rate *@
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.caption">HR: @_clinicalSummary.VitalSigns.HeartRate</MudText>
                    </MudCardContent>
                </MudCard>

                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.caption">Temp: @_clinicalSummary.VitalSigns.TemperatureFahrenheit°F</MudText>
                    </MudCardContent>
                </MudCard>

                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.caption">SpO2: @_clinicalSummary.VitalSigns.OxygenSaturation%</MudText>
                    </MudCardContent>
                </MudCard>
            </MudPaper>

            @* chief complaint *@
            <MudPaper Elevation="3">
                <MudFab Label="📝" />
                <MudText Typo="Typo.h6">Chief Complaint</MudText>
                <MudStack>
                    <MudText Typo="Typo.caption">
                        @_clinicalSummary.ChiefComplaint
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    private readonly ClinicalSummary _clinicalSummary = new()
    {
        ClinicId = 9001,
        MedicalRecordNumber = "8888",
        ChiefComplaint = "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.",
    };

    protected override void OnInitialized()
    {
        _clinicalSummary.SetBloodPressure(138, 88);
        _clinicalSummary.SetHeartRate(96);
        _clinicalSummary.SetTemperature(98.6);
        _clinicalSummary.SetOxygenSaturation(99);
    }
}
