@page "/provider-portal/ClinicalSummary/{MedicalRecordNumber}"

@using PatientCare.Application.Diagnostics
@using PatientCare.Application.Diagnostics.Features
@using PatientCare.UI.Shared.Components
@using PatientCare.UI.Shared.Services
@using MudBlazor
@using SharedKernel

<PageTitle>Provider Portal</PageTitle>

<MudPaper Class="page-background rounded-0 pt-9 pb-2" MinHeight="100vh" Width="100vw">
	<MudStack Spacing="3" Class="m-4">
		@* clinic *@
		<MudText Typo="Typo.h4" Align="Align.Center">Clinic Id: @clinicalSummary.ClinicId</MudText>
		<MudText Typo="Typo.h4" Align="Align.Center">MRN: @clinicalSummary.MedicalRecordNumber</MudText>

		@* navigation *@
		<DomainNavigation />
		<PatientNavigation />

		@* summary details *@
		<MudPaper Elevation="3" Class="p-4">
			<MudText Typo="Typo.caption">🤖 AI-Generated Clinical Summary</MudText>
			<MudGrid Spacing="4">
				@* vital signs *@
				<MudItem xs="12" md="6">
					<MudPaper Elevation="5" Class="p-3">
					<MudPaper Elevation="0" Class="d-flex gap-2">
						<MudPaper Class="rounded-circle d-flex overflow-hidden justify-center align-center"
									Elevation="0"
									Height="3rem"
									Width="3rem"
									Style="background-color: #FEE2E2F2;">
							<MudText Align="Align.Center" Typo="Typo.body1">
								📊
							</MudText>
						</MudPaper>
						<MudText Typo="Typo.h6" Class="d-flex flex-fill align-center">Vital Signs</MudText>
					</MudPaper>

					<MudPaper Elevation="0" Class="d-flex flex-wrap gap-2 mt-2">
						@* blood preasure *@
						<MudCard>
							<MudCardContent>
								<MudText Typo="Typo.caption">BP: @clinicalSummary.VitalSigns.BloodPressureDiastolic/@clinicalSummary.VitalSigns.BloodPressureSystolic</MudText>
							</MudCardContent>
						</MudCard>

						@* heart rate *@
						<MudCard>
							<MudCardContent>
								<MudText Typo="Typo.caption">HR: @clinicalSummary.VitalSigns.HeartRate</MudText>
							</MudCardContent>
						</MudCard>

						<MudCard>
							<MudCardContent>
								<MudText Typo="Typo.caption">Temp: @clinicalSummary.VitalSigns.TemperatureFahrenheit°F</MudText>
							</MudCardContent>
						</MudCard>

						<MudCard>
							<MudCardContent>
								<MudText Typo="Typo.caption">SpO2: @clinicalSummary.VitalSigns.OxygenSaturation%</MudText>
							</MudCardContent>
						</MudCard>
					</MudPaper>
				</MudPaper>
				</MudItem>

				@* chief complaint *@
				<MudItem xs="12" md="6">
					<MudPaper Elevation="5" Class="p-3">
						<MudPaper Elevation="0" Class="d-flex gap-2">
							<MudPaper Class="rounded-circle d-flex overflow-hidden justify-center align-center"
										Elevation="0"
										Height="3rem"
										Width="3rem"
										Style="background-color: #DBEAFEF2;">
								<MudText Align="Align.Center" Typo="Typo.body1">
									📝
								</MudText>
							</MudPaper>
							<MudText Typo="Typo.h6" Class="d-flex flex-fill align-center">Chief Complaint</MudText>
						</MudPaper>

						<MudText Typo="Typo.caption" Class="mt-2" Style="word-break: break-word; white-space: pre-wrap; overflow-wrap: anywhere; max-width: 100%;">
							@clinicalSummary.ChiefComplaint
						</MudText>
					</MudPaper>
				</MudItem>
			</MudGrid>
		</MudPaper>
	</MudStack>
</MudPaper>

@code {
	[Inject]
	private Mediator Mediator { get; set; } = null!;

	private int ClinicId = int.Parse(Environment.GetEnvironmentVariable("CLINIC_ID") ?? throw new ArgumentNullException("CLINIC_ID environment variable has not been set."));
	[Parameter] public string? MedicalRecordNumber { get; set; }

	private ClinicalSummary clinicalSummary { get; set; } = new ClinicalSummary();

	protected override async Task OnInitializedAsync()
	{
		await GetClinicalSummary();

		clinicalSummary.SetBloodPressure(138, 88);
		clinicalSummary.SetHeartRate(96);
		clinicalSummary.SetTemperature(98.6);
		clinicalSummary.SetOxygenSaturation(99);
	}

	private async Task GetClinicalSummary()
	{
		var request = new GetClinicalSummariesByClinicId.Request(ClinicId);
		var response = await Mediator.Send<GetClinicalSummariesByClinicId.Request, GetClinicalSummariesByClinicId.Response>(request);
		if(response.IsSuccess)
			clinicalSummary = response.Value.ClinicalSummaries.FirstOrDefault(x => x.MedicalRecordNumber == MedicalRecordNumber) ?? new ClinicalSummary();

	}
}
