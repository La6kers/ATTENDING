# ============================================================
# ATTENDING AI Platform - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# -------------------------------------------------------------
# DATABASE
# -------------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/attending_dev"

# -------------------------------------------------------------
# NEXT.JS / AUTHENTICATION
# -------------------------------------------------------------
NEXTAUTH_SECRET="your-32-character-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Session timeout (8 hours for clinical shifts)
SESSION_MAX_AGE=28800

# -------------------------------------------------------------
# AZURE AD B2C (Production Authentication)
# -------------------------------------------------------------
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""
AZURE_AD_B2C_TENANT_NAME=""

# -------------------------------------------------------------
# AI SERVICES
# -------------------------------------------------------------
# BioMistral Configuration
BIOMISTRAL_API_URL="http://localhost:11434"
BIOMISTRAL_MODEL="biomistral-7b"
BIOMISTRAL_API_KEY=""

# OpenAI (Fallback)
OPENAI_API_KEY=""

# -------------------------------------------------------------
# REAL-TIME / WEBSOCKET
# -------------------------------------------------------------
WEBSOCKET_URL="ws://localhost:3003"
WEBSOCKET_PORT=3003

# -------------------------------------------------------------
# EXTERNAL SERVICES
# -------------------------------------------------------------
# FHIR Server (Epic, Oracle Health)
FHIR_BASE_URL=""
FHIR_CLIENT_ID=""
FHIR_CLIENT_SECRET=""

# Drug Interaction API
DRUG_INTERACTION_API_URL=""
DRUG_INTERACTION_API_KEY=""

# Geolocation (for emergency facility finding)
GOOGLE_MAPS_API_KEY=""

# -------------------------------------------------------------
# FEATURE FLAGS
# -------------------------------------------------------------
ENABLE_AI_RECOMMENDATIONS=true
ENABLE_REAL_TIME_NOTIFICATIONS=true
ENABLE_DRUG_INTERACTIONS=true
ENABLE_EMERGENCY_PROTOCOLS=true

# -------------------------------------------------------------
# DEVELOPMENT
# -------------------------------------------------------------
NODE_ENV="development"
LOG_LEVEL="debug"

# Auth bypass for development (set to 'true' to skip authentication)
DEV_BYPASS_AUTH=false
SKIP_AUTH=false

# Port Configuration
PROVIDER_PORTAL_PORT=3002
PATIENT_PORTAL_PORT=3001

# -------------------------------------------------------------
# HIPAA COMPLIANCE
# -------------------------------------------------------------
# Enable comprehensive audit logging
ENABLE_AUDIT_LOGGING=true

# Session security
SECURE_COOKIES=false  # Set to true in production with HTTPS
