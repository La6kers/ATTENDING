# ATTENDING AI — Local Development Environment
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git (it's in .gitignore)

# Database — SQL Server SA password
# Must meet SQL Server complexity requirements (uppercase + lowercase + digit + symbol, 8+ chars)
MSSQL_SA_PASSWORD=YourStrongPassword123!
ATTENDING_DB_PASSWORD=YourStrongPassword123!

# Prisma connection string (used by Next.js BFF layer)
DATABASE_URL="sqlserver://localhost:1433;database=attending_db;user=sa;password=YourStrongPassword123!;trustServerCertificate=true;encrypt=true"

# NextAuth.js session secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-32-char-random-string

# .NET Backend API URL (used by Next.js BFF to proxy requests)
# Docker: http://api:8080  |  Local: http://localhost:5080
ATTENDING_API_URL=http://localhost:5080

# Patient Portal — Default Organization ID
# Required for the patient portal pre-visit flow (assessment submission, compass verify, auth).
# This is a SINGLE-TENANT assumption: all patient portal users are assigned to this organization.
# For multi-tenant patient portal support, this must be replaced with per-request tenant resolution.
DEFAULT_ORGANIZATION_ID=

# Optional: Drug Interaction API (NIH RxNorm is free, no key needed)
# DRUG_INTERACTION_API_URL=https://rxnav.nlm.nih.gov/REST
# DRUG_INTERACTION_API_KEY=

# Optional: Azure AD B2C (required for production auth)
# AZURE_AD_B2C_TENANT_NAME=attendingai
# AZURE_AD_B2C_CLIENT_ID=your-client-id
# AZURE_AD_B2C_CLIENT_SECRET=your-client-secret
