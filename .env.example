# ============================================================
# ATTENDING AI Platform - Environment Variables
# Copy this file to .env.local and fill in your values
# 
# Updated: January 2026 - Phase 1 Production Fundamentals
# ============================================================

# -------------------------------------------------------------
# DATABASE
# -------------------------------------------------------------
# Use docker-compose: postgresql://attending:attending_dev_password@localhost:5432/attending_db
# connection_limit: Max Prisma connections per instance. pool_timeout: Wait seconds.
# Tune connection_limit based on: (pods × limit) ≤ PostgreSQL max_connections
DATABASE_URL="postgresql://attending:attending_dev_password@localhost:5432/attending_db?connection_limit=10&pool_timeout=30"

# -------------------------------------------------------------
# REDIS (Session Store & Rate Limiting)
# -------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -------------------------------------------------------------
# NEXT.JS / AUTHENTICATION
# -------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-32-character-secret-here-generate-securely"
NEXTAUTH_URL="http://localhost:3000"

# Session timeout (8 hours = 28800 seconds for clinical shifts)
SESSION_MAX_AGE=28800

# -------------------------------------------------------------
# AZURE AD B2C (Production Authentication)
# -------------------------------------------------------------
# Required for production deployment
AZURE_AD_B2C_TENANT_NAME=""
AZURE_AD_B2C_CLIENT_ID=""
AZURE_AD_B2C_CLIENT_SECRET=""
AZURE_AD_B2C_PRIMARY_USER_FLOW="B2C_1_SignUpSignIn"

# Optional: Separate patient authentication flow
AZURE_AD_B2C_PATIENT_CLIENT_ID=""
AZURE_AD_B2C_PATIENT_CLIENT_SECRET=""
AZURE_AD_B2C_PATIENT_USER_FLOW="B2C_1_PatientSignUpSignIn"

# Legacy variable names (deprecated, use B2C versions above)
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# -------------------------------------------------------------
# AI SERVICES
# -------------------------------------------------------------
# BioMistral Configuration (local deployment)
BIOMISTRAL_API_URL="http://localhost:11434"
BIOMISTRAL_MODEL="biomistral-7b"
BIOMISTRAL_API_KEY=""

# OpenAI (Fallback for differential diagnosis)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4-turbo-preview"

# -------------------------------------------------------------
# REAL-TIME / WEBSOCKET
# -------------------------------------------------------------
# WebSocket server URL (for real-time notifications)
NEXT_PUBLIC_WS_URL="http://localhost:3003"
WEBSOCKET_PORT=3003

# Enable audio alerts for emergencies
ENABLE_AUDIO_ALERTS=true

# -------------------------------------------------------------
# EXTERNAL SERVICES / FHIR
# -------------------------------------------------------------
# Epic FHIR Server
EPIC_FHIR_BASE_URL=""
EPIC_CLIENT_ID=""
EPIC_CLIENT_SECRET=""
EPIC_SMART_SCOPE="patient/*.read user/*.read"

# Oracle Health (Cerner) FHIR Server
ORACLE_FHIR_BASE_URL=""
ORACLE_CLIENT_ID=""
ORACLE_CLIENT_SECRET=""

# Generic FHIR (for testing with HAPI)
FHIR_BASE_URL="http://hapi.fhir.org/baseR4"
FHIR_CLIENT_ID=""
FHIR_CLIENT_SECRET=""

# Drug Interaction API (NIH or commercial)
DRUG_INTERACTION_API_URL=""
DRUG_INTERACTION_API_KEY=""

# Geolocation (for emergency facility finding)
GOOGLE_MAPS_API_KEY=""

# -------------------------------------------------------------
# FEATURE FLAGS
# -------------------------------------------------------------
ENABLE_AI_RECOMMENDATIONS=true
ENABLE_REAL_TIME_NOTIFICATIONS=true
ENABLE_DRUG_INTERACTIONS=true
ENABLE_EMERGENCY_PROTOCOLS=true
ENABLE_VOICE_INPUT=false
ENABLE_CAMERA_CAPTURE=false
ENABLE_FHIR_INTEGRATION=false
ENABLE_OFFLINE_MODE=false

# -------------------------------------------------------------
# DEVELOPMENT
# -------------------------------------------------------------
NODE_ENV="development"
LOG_LEVEL="debug"

# Auth bypass for development (set to 'true' to skip authentication)
# WARNING: Never enable in production!
DEV_BYPASS_AUTH=false
NEXT_PUBLIC_DEV_BYPASS_AUTH=false

# Port Configuration
PROVIDER_PORTAL_PORT=3000
PATIENT_PORTAL_PORT=3001
WEBSOCKET_SERVER_PORT=3003

# -------------------------------------------------------------
# HIPAA COMPLIANCE & SECURITY
# -------------------------------------------------------------
# Enable comprehensive audit logging (required for HIPAA)
ENABLE_AUDIT_LOGGING=true

# Session security
SECURE_COOKIES=false  # Set to true in production with HTTPS

# Session encryption key (generate with: openssl rand -base64 32)
SESSION_ENCRYPTION_KEY=""

# Encryption key for PHI at rest (generate with: openssl rand -base64 32)
PHI_ENCRYPTION_KEY=""

# CORS - Comma-separated allowed origins for cross-portal API calls
# In development, localhost:3000/3001/3003 are allowed automatically
# CORS_ALLOWED_ORIGINS="https://provider.attending.ai,https://patient.attending.ai"

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# PHI Cache Timeout (seconds)
# Patient data fetched from external EHRs auto-expires after this duration.
# Provider must re-fetch from Epic/Cerner/etc. when cache expires.
# Default: 14400 (4 hours). Set per-category overrides in code.
PHI_CACHE_TTL_SECONDS=14400

# -------------------------------------------------------------
# MONITORING & OBSERVABILITY
# -------------------------------------------------------------
# Sentry error tracking
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# Azure Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=""

# -------------------------------------------------------------
# EMAIL (for notifications)
# -------------------------------------------------------------
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@attending.ai"
