# ============================================================
# ATTENDING Medical AI - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Claude API (Required for AI features)
ANTHROPIC_API_KEY=your-api-key-here

# Server
PORT=3001
NODE_ENV=development

# Database — Local development uses SQLite via sql.js
DB_PATH=./data/attending.db

# Database — Azure SQL (production, uncomment when ready)
# DATABASE_URL="sqlserver://your-server.database.windows.net:1433;database=attending;user=attendingadmin;password=YOUR_PASSWORD;encrypt=true;trustServerCertificate=false"

# Frontend
VITE_API_URL=http://localhost:3001/api

# CORS — comma-separated allowed origins (production only)
# ALLOWED_ORIGINS=https://attending-ai.azurewebsites.net,https://app.attending.ai

# ============================================================
# Azure-specific (set in App Service Configuration, not here)
# ============================================================
# WEBSITES_PORT=8080
# DOCKER_ENABLE_CI=true
# WEBSITES_ENABLE_APP_SERVICE_STORAGE=true
#
# Azure Key Vault references (use in App Service config):
# ANTHROPIC_API_KEY=@Microsoft.KeyVault(SecretUri=https://attending-kv.vault.azure.net/secrets/anthropic-api-key)
# DATABASE_URL=@Microsoft.KeyVault(SecretUri=https://attending-kv.vault.azure.net/secrets/database-url)

# ============================================================
# Local SQL Server (docker-compose)
# ============================================================
# MSSQL_SA_PASSWORD=Attending_Dev_2024!
