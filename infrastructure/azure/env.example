# ============================================================
# ATTENDING AI — Azure Deployment Environment Variables
# infrastructure/azure/env.example
#
# Copy to .env and fill in your values before running deploy.sh
# ============================================================

# Azure environment (production, staging, dev)
AZURE_ENV=production

# Resource group
AZURE_RG=attending-production-rg
AZURE_LOCATION=eastus

# Container Registry
AZURE_ACR=attendingacr

# SQL Server
AZURE_SQL_SERVER=attending-sql-production
AZURE_SQL_DB=attending-db-production
AZURE_SQL_ADMIN=attendingadmin

# Redis
AZURE_REDIS=attending-redis-production

# App Service
AZURE_PLAN=attending-plan-production
AZURE_PORTAL_APP=attending-portal-production
AZURE_API_APP=attending-api-production

# Storage (audit log archival)
AZURE_STORAGE=attendingstorageproduction

# Key Vault
AZURE_KV=attending-kv-production
