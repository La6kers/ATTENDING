# ============================================================
# ATTENDING AI - Production Environment Variables
# env.production.example → Copy to .env.production.local
#
# Phase 4: Azure deployment configuration.
# Secrets are stored in Azure Key Vault and referenced via
# @Microsoft.KeyVault(SecretUri=...) in App Service config.
# This file documents the required variables.
# ============================================================

# ----- Database (Azure SQL) -----
# Prisma connection string format for Azure SQL
# In Azure App Service: set via Key Vault reference
DATABASE_URL="sqlserver://sql-attending-production.database.windows.net:1433;database=attending_db;user=attendingadmin;password=CHANGE_ME;encrypt=true;trustServerCertificate=false"

# ----- Authentication -----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_WITH_OPENSSL"
# Must match the App Service custom domain or default hostname
NEXTAUTH_URL="https://app-attending-production-provider.azurewebsites.net"

# ----- Redis (Azure Cache for Redis) -----
REDIS_URL="rediss://:ACCESS_KEY@redis-attending-production.redis.cache.windows.net:6380"

# ----- Application -----
NODE_ENV="production"
LOG_LEVEL="warn"
NEXT_TELEMETRY_DISABLED="1"

# ----- Feature Flags -----
ENABLE_AI_RECOMMENDATIONS=true
ENABLE_DRUG_INTERACTIONS=true
ENABLE_EMERGENCY_PROTOCOLS=true
ENABLE_AUDIT_LOGGING=true

# ----- .NET Backend API (provider portal → orders API) -----
BACKEND_API_URL="https://app-attending-production-api.azurewebsites.net"
BACKEND_API_KEY="CHANGE_ME"

# ----- Monitoring -----
SENTRY_DSN=""
APPLICATIONINSIGHTS_CONNECTION_STRING=""

# ----- HIPAA Compliance -----
# Health check secret (require auth for detailed health endpoint)
HEALTH_CHECK_SECRET="CHANGE_ME"
# Session timeout: 8 hours (clinical shift alignment)
SESSION_MAX_AGE=28800

# ----- Azure Key Vault (for App Service Key Vault references) -----
# These are set automatically when using managed identity.
# KEY_VAULT_URI="https://kv-attending-production.vault.azure.net/"
