# ============================================================
# ATTENDING AI - Environment Configuration for HIPAA Compliance
# .env.production.example
#
# IMPORTANT: This file documents required environment variables
# for a HIPAA-compliant production deployment.
#
# Copy this file and update values for your environment.
# NEVER commit actual secrets to version control.
# ============================================================

# ------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_APP_NAME="ATTENDING AI"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_ENVIRONMENT="production"

# Application URLs
NEXTAUTH_URL=https://provider.attending.health
PATIENT_PORTAL_URL=https://patient.attending.health

# ------------------------------------------------------------
# DATABASE - HIPAA REQUIREMENT: Encryption at Rest
# ------------------------------------------------------------
# Use PostgreSQL with SSL/TLS and encryption at rest enabled
# Azure Database for PostgreSQL or AWS RDS recommended
DATABASE_URL="postgresql://user:password@hostname:5432/attending_prod?sslmode=require&sslrootcert=/path/to/ca-cert.pem"

# Database connection pool settings
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
DATABASE_CONNECTION_TIMEOUT=30000

# ------------------------------------------------------------
# AUTHENTICATION - HIPAA REQUIREMENT: Access Controls
# ------------------------------------------------------------
# NextAuth secret - generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-256-bit-secret-here"

# Azure AD B2C Configuration (recommended for healthcare)
AZURE_AD_B2C_TENANT_NAME="your-tenant"
AZURE_AD_B2C_CLIENT_ID="your-client-id"
AZURE_AD_B2C_CLIENT_SECRET="your-client-secret"
AZURE_AD_B2C_PRIMARY_USER_FLOW="B2C_1_signupsignin"

# OAuth providers (if not using Azure AD B2C)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ------------------------------------------------------------
# ENCRYPTION - HIPAA REQUIREMENT: Encryption in Transit & Rest
# ------------------------------------------------------------
# 32-byte (64 hex characters) encryption key for PHI
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-64-character-hex-encryption-key"

# Session encryption key (separate from PHI encryption)
SESSION_ENCRYPTION_KEY="your-64-character-hex-session-key"

# JWT signing key
JWT_SECRET="your-jwt-secret-here"

# ------------------------------------------------------------
# REDIS - For Distributed Rate Limiting & Sessions
# ------------------------------------------------------------
# Use Redis with TLS enabled
REDIS_URL="rediss://user:password@hostname:6380"
REDIS_TLS_ENABLED=true

# ------------------------------------------------------------
# AUDIT LOGGING - HIPAA REQUIREMENT: Audit Controls
# ------------------------------------------------------------
# Enable comprehensive audit logging
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_LEVEL="info"

# External audit log service (optional but recommended)
# AUDIT_SERVICE_URL="https://audit.your-siem-provider.com"
# AUDIT_SERVICE_API_KEY="your-api-key"

# Log retention (HIPAA requires 6 years minimum)
AUDIT_LOG_RETENTION_DAYS=2190

# ------------------------------------------------------------
# SECURITY HEADERS & POLICIES
# ------------------------------------------------------------
# Content Security Policy
CSP_REPORT_URI="https://your-csp-report-endpoint.com"

# Allowed origins for CORS
ALLOWED_ORIGINS="https://provider.attending.health,https://patient.attending.health"

# ------------------------------------------------------------
# FHIR/EHR INTEGRATION
# ------------------------------------------------------------
# Epic FHIR Configuration
EPIC_FHIR_BASE_URL="https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4"
EPIC_CLIENT_ID="your-epic-client-id"
EPIC_PRIVATE_KEY_PATH="/path/to/epic-private-key.pem"

# Cerner/Oracle Health FHIR Configuration
CERNER_FHIR_BASE_URL="https://fhir.cerner.com/r4"
CERNER_CLIENT_ID="your-cerner-client-id"
CERNER_CLIENT_SECRET="your-cerner-client-secret"

# ------------------------------------------------------------
# AI SERVICES
# ------------------------------------------------------------
# BioMistral or other AI service
AI_SERVICE_URL="https://ai.your-provider.com"
AI_SERVICE_API_KEY="your-ai-api-key"

# OpenAI (if used for non-PHI tasks)
# OPENAI_API_KEY="sk-..."

# ------------------------------------------------------------
# FILE STORAGE - HIPAA REQUIREMENT: PHI Storage Security
# ------------------------------------------------------------
# Azure Blob Storage (recommended for healthcare)
AZURE_STORAGE_ACCOUNT="your-storage-account"
AZURE_STORAGE_KEY="your-storage-key"
AZURE_STORAGE_CONTAINER="phi-documents"

# Or AWS S3 with encryption
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET=""
# AWS_S3_REGION=""
# AWS_KMS_KEY_ID=""  # For server-side encryption

# ------------------------------------------------------------
# EMAIL SERVICE (for notifications)
# ------------------------------------------------------------
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASSWORD="your-sendgrid-api-key"
SMTP_FROM="noreply@attending.health"

# ------------------------------------------------------------
# MONITORING & ALERTING
# ------------------------------------------------------------
# Application Performance Monitoring
# SENTRY_DSN="https://xxx@sentry.io/xxx"
# NEW_RELIC_LICENSE_KEY=""
# DATADOG_API_KEY=""

# Health check endpoints
HEALTH_CHECK_SECRET="your-health-check-secret"

# ------------------------------------------------------------
# RATE LIMITING CONFIGURATION
# ------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_STRICT_MAX_REQUESTS=20
RATE_LIMIT_AUTH_MAX_REQUESTS=10

# ------------------------------------------------------------
# SESSION CONFIGURATION
# ------------------------------------------------------------
# 8-hour clinical shift sessions
SESSION_DURATION_HOURS=8
SESSION_INACTIVITY_TIMEOUT_MINUTES=30
SESSION_MAX_DURATION_HOURS=12

# ------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------
# Static feature flags (simple on/off)
FEATURE_AI_DIFFERENTIAL_DIAGNOSIS=false
FEATURE_AI_DRUG_RECOMMENDATIONS=false
FEATURE_AI_LAB_ORDERING=true
FEATURE_AMBIENT_DOCUMENTATION=false
FEATURE_TELEHEALTH=false

# Remote Feature Flag Provider (recommended for multi-site management)
# Supports: 'launchdarkly' | 'unleash' | 'custom'
# Unleash is open-source and recommended for healthcare (self-hosted = data control)
FEATURE_FLAG_PROVIDER="unleash"
FEATURE_FLAG_URL="https://unleash.your-domain.com/api"
FEATURE_FLAG_KEY="your-unleash-api-token"
# FEATURE_FLAG_REFRESH_INTERVAL_MS=30000

# ------------------------------------------------------------
# AUDIT LOG ARCHIVAL - Cold Storage for HIPAA 6-Year Retention
# ------------------------------------------------------------
# Azure Blob Storage for audit log archival (90+ day old logs)
# Lifecycle: Hot (0-90d) → Cool (90-365d) → Archive (365d+) → Delete (6yr)
AZURE_AUDIT_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net"
AZURE_AUDIT_STORAGE_CONTAINER="audit-logs-archive"
AUDIT_ARCHIVAL_BATCH_SIZE=1000
AUDIT_ARCHIVAL_RETENTION_DAYS=90

# ------------------------------------------------------------
# WEBSOCKET SCALING
# ------------------------------------------------------------
# Redis adapter for Socket.io horizontal scaling
# Uses same REDIS_URL above. Separate pub/sub connection is automatic.
WEBSOCKET_PORT=3001
WEBSOCKET_MAX_CONNECTIONS_PER_IP=10
WEBSOCKET_RATE_LIMIT_WINDOW_MS=60000
WEBSOCKET_HEARTBEAT_INTERVAL_MS=25000
WEBSOCKET_HEARTBEAT_TIMEOUT_MS=60000

# ------------------------------------------------------------
# DEPLOYMENT NOTES
# ------------------------------------------------------------
# 
# 1. NEVER commit this file with real values
# 2. Use a secrets manager (Azure Key Vault, AWS Secrets Manager, HashiCorp Vault)
# 3. Rotate secrets regularly (minimum quarterly)
# 4. Enable audit logging for secrets access
# 5. Use separate keys for each environment (dev, staging, prod)
# 6. Document all security controls for HIPAA compliance
#
# Required infrastructure for HIPAA compliance:
# - TLS 1.2+ for all connections
# - Encryption at rest for database and file storage
# - Network isolation (VPC/VNET)
# - WAF (Web Application Firewall)
# - DDoS protection
# - Intrusion detection
# - Regular penetration testing
# - Backup and disaster recovery plan
# ============================================================
