{
  "expo": {
    "name": "ATTENDING AI",
    "slug": "attending-ai",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "attending-ai",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C4C5E"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.attendingai.mobile",
      "infoPlist": {
        "NSMotionUsageDescription": "ATTENDING AI uses motion sensors for crash detection in emergency access mode."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0C4C5E"
      },
      "package": "com.attendingai.mobile",
      "permissions": ["HIGH_SAMPLING_RATE_SENSORS"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-sensors"],
    "experiments": {
      "typedRoutes": true
    },
    "primaryColor": "#0C4C5E"
  }
}
