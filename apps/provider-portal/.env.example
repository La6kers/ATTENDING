# =============================================================================
# ATTENDING AI - Complete Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in all required values
# Required fields are marked with [REQUIRED]
# =============================================================================

# =============================================================================
# DATABASE [REQUIRED]
# =============================================================================
# SQLite for development:
DATABASE_URL="file:./dev.db"

# PostgreSQL for production:
# DATABASE_URL="postgresql://user:password@host:5432/attending?schema=public"

# =============================================================================
# AUTHENTICATION [REQUIRED]
# =============================================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secure-secret-here-generate-with-openssl"
NEXTAUTH_URL="http://localhost:3000"

# Session settings
SESSION_TIMEOUT_MINUTES=480

# Optional: Azure AD B2C (for enterprise SSO)
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=

# =============================================================================
# BIOMISTRAL AI CONFIGURATION [REQUIRED FOR AI FEATURES]
# =============================================================================

# Provider: ollama | huggingface | replicate | openai-compatible
BIOMISTRAL_PROVIDER="ollama"

# Ollama (recommended for development - run locally)
BIOMISTRAL_OLLAMA_ENDPOINT="http://localhost:11434/api/generate"
BIOMISTRAL_MODEL="biomistral:7b"

# HuggingFace (cloud option)
# BIOMISTRAL_PROVIDER="huggingface"
# BIOMISTRAL_API_KEY="hf_your_api_key_here"
# BIOMISTRAL_HF_ENDPOINT="https://api-inference.huggingface.co/models/BioMistral/BioMistral-7B"

# Replicate (cloud option)
# BIOMISTRAL_PROVIDER="replicate"
# REPLICATE_API_TOKEN="r8_your_token_here"

# OpenAI-compatible (for custom deployments like vLLM, TGI)
# BIOMISTRAL_PROVIDER="openai-compatible"
# BIOMISTRAL_OPENAI_ENDPOINT="http://localhost:8000/v1/chat/completions"

# AI Model Parameters
BIOMISTRAL_TEMPERATURE=0.3
BIOMISTRAL_MAX_TOKENS=2048

# Fallback mode when AI unavailable: rule-based | error | cache
AI_FALLBACK_MODE="rule-based"

# Confidence thresholds (0.0 - 1.0)
AI_THRESHOLD_DIFFERENTIAL=0.70
AI_THRESHOLD_TREATMENT=0.75
AI_THRESHOLD_MEDICATION=0.85
AI_THRESHOLD_LABS=0.75
AI_THRESHOLD_IMAGING=0.75

# Rate limiting
AI_RATE_LIMIT_RPM=60
AI_RATE_LIMIT_TPM=100000

# Caching
AI_CACHE_ENABLED=true
AI_CACHE_TTL=3600

# Audit logging
AI_AUDIT_ENABLED=true

# =============================================================================
# FHIR / EHR INTEGRATION
# =============================================================================

# Enable FHIR integration
FHIR_ENABLED=false

# Epic FHIR R4 Server
# FHIR_SERVER_URL="https://your-epic-server/api/FHIR/R4"
# FHIR_CLIENT_ID=""
# FHIR_CLIENT_SECRET=""
# FHIR_SCOPE="patient/*.read patient/*.write"

# Cerner FHIR R4 Server
# FHIR_SERVER_URL="https://your-cerner-server/api/FHIR/R4"

# =============================================================================
# E-PRESCRIBING / SURESCRIPTS
# =============================================================================

SURESCRIPTS_ENABLED=false
# SURESCRIPTS_ENDPOINT=""
# SURESCRIPTS_ACCOUNT_ID=""
# SURESCRIPTS_API_KEY=""

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# AI Features
FEATURE_AI_RECOMMENDATIONS=true
FEATURE_AI_DIFFERENTIAL=true
FEATURE_AI_TREATMENT=true
FEATURE_AI_LABS=true
FEATURE_AI_IMAGING=true
FEATURE_AI_NOTES=true
FEATURE_AI_EDUCATION=true
FEATURE_AI_PRIOR_AUTH=false

# Platform Features
FEATURE_REAL_TIME_NOTIFICATIONS=true
FEATURE_VOICE_INPUT=false
FEATURE_AMBIENT_LISTENING=false
FEATURE_DARK_MODE=true
FEATURE_MULTI_LANGUAGE=false

# =============================================================================
# NOTIFICATIONS & REAL-TIME
# =============================================================================

# WebSocket endpoint for real-time updates
WEBSOCKET_URL="ws://localhost:3000/ws"

# Polling fallback intervals (ms)
NOTIFICATION_POLL_INTERVAL=30000
CRITICAL_ALERT_POLL_INTERVAL=10000

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================

# Twilio for SMS notifications
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""

# SendGrid for email notifications
# SENDGRID_API_KEY=""
# SENDGRID_FROM_EMAIL=""

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Sentry error tracking
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT="development"

# DataDog APM
# DATADOG_API_KEY=""
# DATADOG_APP_KEY=""

# Application Insights
# APPINSIGHTS_INSTRUMENTATION_KEY=""

# Google Analytics
# GA_MEASUREMENT_ID=""

# =============================================================================
# SECURITY
# =============================================================================

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# API request timeout (ms)
API_TIMEOUT_MS=30000

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Debug mode (enables verbose logging)
DEBUG_MODE=false

# Use mock data (for offline development)
USE_MOCK_DATA=false

# Skip authentication (NEVER in production)
SKIP_AUTH=false

# Log all SQL queries
LOG_SQL_QUERIES=false

# =============================================================================
# QUICK START GUIDE
# =============================================================================
#
# 1. Copy this file to .env.local:
#    cp .env.example .env.local
#
# 2. Generate a secure NEXTAUTH_SECRET:
#    [System.Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
#
# 3. For AI features, install Ollama and pull BioMistral:
#    winget install Ollama.Ollama
#    ollama pull biomistral:7b
#
# 4. Initialize the database:
#    npx prisma migrate dev
#    npx prisma db seed
#
# 5. Start the development server:
#    npm run dev
#
# =============================================================================
