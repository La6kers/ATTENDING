{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@attending/shared": ["../shared"],
      "@attending/shared/*": ["../shared/*"],
      "@attending/clinical-services": ["../../packages/clinical-services/src"],
      "@attending/clinical-services/*": ["../../packages/clinical-services/src/*"],
      "@attending/clinical-types": ["../../packages/clinical-types/src"],
      "@attending/clinical-types/*": ["../../packages/clinical-types/src/*"],
      "@attending/ui-primitives": ["../../packages/ui-primitives/src"],
      "@attending/ui-primitives/*": ["../../packages/ui-primitives/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "../shared/**/*.ts", "../../packages/clinical-services/src/**/*.ts", "../../packages/clinical-types/src/**/*.ts", "../../packages/ui-primitives/src/**/*.ts", "../../packages/ui-primitives/src/**/*.tsx"],
  "exclude": ["node_modules", "__tests__", "e2e", "*.test.ts", "*.spec.ts"]
}
