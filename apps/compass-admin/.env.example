# =============================================================================
# ATTENDING AI - COMPASS Admin Panel Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env or .env.local to git.
# =============================================================================

# =============================================================================
# AUTHENTICATION [REQUIRED]
# =============================================================================

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-32-char-random-string"

# COMPASS admin panel URL (default port 4502)
NEXTAUTH_URL="http://localhost:4502"

# =============================================================================
# DATABASE [REQUIRED]
# =============================================================================

# Prisma connection string
# SQL Server: sqlserver://localhost:1433;database=attending_db;user=sa;password=...;trustServerCertificate=true;encrypt=true
# SQLite (dev): file:./dev.db
DATABASE_URL="sqlserver://localhost:1433;database=attending_db;user=sa;password=YourStrongPassword123!;trustServerCertificate=true;encrypt=true"

# =============================================================================
# BACKEND API
# =============================================================================

# .NET backend API URL
# Docker: http://api:8080  |  Local: http://localhost:5080
ATTENDING_API_URL="http://localhost:5080"
