# =============================================================================
# ATTENDING AI - Patient Portal Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Required fields are marked with [REQUIRED].
# NEVER commit .env or .env.local to git.
# =============================================================================

# =============================================================================
# AUTHENTICATION [REQUIRED]
# =============================================================================

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-32-char-random-string"

# Patient portal runs on port 4501 by default
NEXTAUTH_URL="http://localhost:4501"

# Demo mode bypasses real auth for local development
# DEMO_MODE=true

# =============================================================================
# ORGANIZATION [REQUIRED]
# =============================================================================

# Single-tenant organization ID. All patient portal users are assigned to this
# organization. Used by COMPASS verify, assessment submission, and auth token.
# For multi-tenant support, replace with per-request tenant resolution.
DEFAULT_ORGANIZATION_ID=

# =============================================================================
# BACKEND API
# =============================================================================

# .NET backend URL used by server-side API routes
# Docker: http://api:8080  |  Local: http://localhost:5000
BACKEND_URL="http://localhost:5000"

# Public API base URL exposed to browser (client-side fetch calls)
# NEXT_PUBLIC_API_URL="/api"

# Public backend URL for client-side API calls
# NEXT_PUBLIC_BACKEND_URL="http://localhost:5000"

# =============================================================================
# REAL-TIME NOTIFICATIONS
# =============================================================================

# SignalR hub URL for clinical notifications (useNotifications hook)
# NEXT_PUBLIC_SIGNALR_URL="http://localhost:5000/hubs/clinical"

# WebSocket URL for real-time updates (useWebSocket hook)
# NEXT_PUBLIC_WS_URL="http://localhost:5260"

# =============================================================================
# SPEECH-TO-TEXT (for voice input / transcription)
# =============================================================================

# Option A: OpenAI Whisper API
# OPENAI_API_KEY="sk-your-openai-key"

# Option B: Azure Speech Services
# AZURE_SPEECH_KEY="your-azure-speech-key"
# AZURE_SPEECH_REGION="eastus"

# =============================================================================
# PUSH NOTIFICATIONS (optional, for mobile PWA)
# =============================================================================

# Firebase Cloud Messaging server key
# FCM_SERVER_KEY=""

# Apple Push Notification Service
# APNS_KEY_ID=""
# APNS_TEAM_ID=""

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Set NODE_ENV explicitly if needed (Next.js sets this automatically)
# NODE_ENV=development
