# ============================================================
# COMPASS Standalone — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# --- AI Vision (Photo Analysis) ---
# Claude Vision (primary) — https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Azure OpenAI Vision (fallback)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4-vision

# --- AI Diagnosis Engine ---
# Provider: local | anthropic | azure-openai | biomistral
AI_PROVIDER=local
AI_ENDPOINT=
AI_API_KEY=
AI_MODEL=

# --- Assessment Sharing ---
# Secret for HMAC signing share URLs (optional, defaults to app-derived key)
SHARE_SECRET=

# ============================================================
# Note: With no API keys, COMPASS falls back to local
# rule-based diagnosis and skips image analysis.
# ============================================================
