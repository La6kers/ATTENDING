{
  "ConnectionStrings": {
    "AttendingDb": "Server=localhost,1433;Database=attending_db;User Id=sa;Password=#{ATTENDING_DB_PASSWORD}#;TrustServerCertificate=True;MultipleActiveResultSets=true",
    "Redis": ""
  },
  "DrugInteractionApi": {
    "BaseUrl": "",
    "ApiKey": "",
    "TimeoutSeconds": 10,
    "SourceName": "NIH-RxNorm"
  },
  "OpenFda": {
    "BaseUrl": "https://api.fda.gov/drug",
    "ApiKey": "",
    "TimeoutSeconds": 10,
    "MinReportThreshold": 50
  },
  "DrugInteractionCache": {
    "Enabled": true
  },
  "AzureAdB2C": {
    "Instance": "https://attendingai.b2clogin.com",
    "Domain": "attendingai.onmicrosoft.com",
    "ClientId": "",
    "Authority": "https://attendingai.b2clogin.com/attendingai.onmicrosoft.com/B2C_1_signupsignin1/v2.0"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://localhost:3002",
      "https://provider.attendingai.com",
      "https://patient.attendingai.com"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName"
    ]
  },
  "FhirCerner": {
    "BaseUrl": "",
    "ClientId": "",
    "ClientSecret": "",
    "TokenEndpoint": "",
    "Scope": "system/Patient.read system/Observation.read system/MedicationRequest.read system/Condition.read system/AllergyIntolerance.read system/ServiceRequest.write"
  },
  "HealthChecks": {
    "Enabled": true
  },
  "EventBus": {
    "Transport": "InProcess",
    "ConnectionString": "",
    "FullyQualifiedNamespace": "",
    "FifoOrdering": false
  },
  "AllowedHosts": "*",
  "OpenTelemetry": {
    "ServiceName": "attending-orders-api",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "",
    "ConsoleExporter": true
  },
  "PerformanceSla": {
    "DefaultMs": 1000,
    "Routes": [
      { "Method": "GET",   "PathPrefix": "/health",                             "ThresholdMs": 100  },
      { "Method": "GET",   "PathPrefix": "/api/v1/laborders/critical",           "ThresholdMs": 150  },
      { "Method": "GET",   "PathPrefix": "/api/v1/laborders/pending",            "ThresholdMs": 200  },
      { "Method": "GET",   "PathPrefix": "/api/v1/patients/search",             "ThresholdMs": 250  },
      { "Method": "GET",   "PathPrefix": "/api/v1/patients",                    "ThresholdMs": 200  },
      { "Method": "GET",   "PathPrefix": "/api/v1/encounters",                  "ThresholdMs": 200  },
      { "Method": "GET",   "PathPrefix": "/api/v1/laborders",                   "ThresholdMs": 200  },
      { "Method": "GET",   "PathPrefix": "/api/v1/assessments",                 "ThresholdMs": 200  },
      { "Method": "POST",  "PathPrefix": "/api/v1/patients",                    "ThresholdMs": 500  },
      { "Method": "POST",  "PathPrefix": "/api/v1/encounters",                  "ThresholdMs": 500  },
      { "Method": "POST",  "PathPrefix": "/api/v1/laborders",                   "ThresholdMs": 600  },
      { "Method": "POST",  "PathPrefix": "/api/v1/imagingorders",               "ThresholdMs": 500  },
      { "Method": "POST",  "PathPrefix": "/api/v1/medications",                 "ThresholdMs": 600  },
      { "Method": "POST",  "PathPrefix": "/api/v1/referrals",                   "ThresholdMs": 500  },
      { "Method": "POST",  "PathPrefix": "/api/v1/assessments",                 "ThresholdMs": 800  },
      { "Method": "PATCH", "PathPrefix": "/api/v1/",                            "ThresholdMs": 400  }
    ]
  },
  "RateLimiting": {
    "TenantApi": {
      "PermitLimit": 300,
      "WindowMinutes": 1
    },
    "ClinicalOps": {
      "TokenLimit": 20,
      "ReplenishmentSeconds": 20,
      "TokensPerPeriod": 20
    },
    "Auth": {
      "PermitLimit": 10,
      "WindowMinutes": 1
    }
  }
}
