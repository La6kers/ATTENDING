{
  "ConnectionStrings": {
    "AttendingDb": "",
    "Redis": ""
  },
  "Authentication": {
    "DevBypass": false
  },
  "AzureAdB2C": {
    "Instance": "https://attendingai.b2clogin.com",
    "Domain": "attendingai.onmicrosoft.com",
    "ClientId": "",
    "Authority": "https://attendingai.b2clogin.com/attendingai.onmicrosoft.com/B2C_1_signupsignin1/v2.0"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://app-attending-staging-provider.azurewebsites.net",
      "https://app-attending-staging-patient.azurewebsites.net",
      "https://app-attending-staging-provider-staging.azurewebsites.net",
      "https://app-attending-staging-patient-staging.azurewebsites.net"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "https://seq-attending-staging.azurewebsites.net"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ]
  },
  "OpenTelemetry": {
    "ServiceName": "attending-orders-api",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "",
    "ConsoleExporter": true
  },
  "Features": {
    "EnableFhirIntegration": false,
    "EnableAiRecommendations": true,
    "EnableRealTimeNotifications": true,
    "EnableAuditLogging": true
  },
  "AzureKeyVault": {
    "Uri": ""
  },
  "RateLimiting": {
    "TenantApi": {
      "PermitLimit": 100,
      "WindowMinutes": 1
    },
    "ClinicalOps": {
      "TokenLimit": 10,
      "ReplenishmentSeconds": 20,
      "TokensPerPeriod": 10
    },
    "Auth": {
      "PermitLimit": 10,
      "WindowMinutes": 1
    }
  }
}
