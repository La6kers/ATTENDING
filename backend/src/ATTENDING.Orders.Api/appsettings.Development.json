{
  "ConnectionStrings": {
    "AttendingDb": "Server=localhost,1433;Database=attending_db;User Id=sa;Password=Attending_Dev_2026!;TrustServerCertificate=True;MultipleActiveResultSets=true",
    "Redis": "localhost:6379"
  },
  "AzureAdB2C": {
    "Instance": "https://yourtenantname.b2clogin.com",
    "Domain": "yourtenantname.onmicrosoft.com",
    "ClientId": "your-client-id-here",
    "SignUpSignInPolicyId": "B2C_1_SignIn",
    "TenantId": "your-tenant-id-here"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://localhost:3002"
    ]
  },
  "Authentication": {
    "DevBypass": true
  },
  "SignalR": {
    "EnableDetailedErrors": true,
    "KeepAliveIntervalSeconds": 15,
    "ClientTimeoutIntervalSeconds": 30
  },
  "ClinicalAi": {
    "BaseUrl": "http://localhost:11434/api",
    "Model": "biomistral",
    "TimeoutSeconds": 30
  },
  "FhirClients": {
    "Epic": {
      "BaseUrl": "https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4",
      "ClientId": "",
      "ClientSecret": "",
      "TokenEndpoint": "",
      "Scope": "patient/*.read system/*.read"
    },
    "OracleHealth": {
      "BaseUrl": "https://fhir-myrecord.cerner.com/r4",
      "ClientId": "",
      "ClientSecret": "",
      "TokenEndpoint": "",
      "Scope": "patient/*.read system/*.read"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithEnvironmentName"]
  },
  "Features": {
    "EnableFhirIntegration": true,
    "EnableAiRecommendations": true,
    "EnableRealTimeNotifications": true,
    "EnableAuditLogging": true
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 10
  }
}
