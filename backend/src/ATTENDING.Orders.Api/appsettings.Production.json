{
  "ConnectionStrings": {
    "AttendingDb": "",
    "Redis": ""
  },
  "AzureAdB2C": {
    "Instance": "https://attendingai.b2clogin.com",
    "Domain": "attendingai.onmicrosoft.com",
    "ClientId": "",
    "Authority": "https://attendingai.b2clogin.com/attendingai.onmicrosoft.com/B2C_1_signupsignin1/v2.0"
  },
  "Authentication": {
    "DevBypass": false
  },
  "Cors": {
    "AllowedOrigins": [
      "https://provider.attendingai.com",
      "https://patient.attendingai.com"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "ApplicationInsights",
        "Args": {
          "telemetryConverter": "Serilog.Sinks.ApplicationInsights.TelemetryConverters.TraceTelemetryConverter, Serilog.Sinks.ApplicationInsights"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ]
  },
  "Features": {
    "EnableFhirIntegration": false,
    "EnableAiRecommendations": true,
    "EnableRealTimeNotifications": true,
    "EnableAuditLogging": true
  }
}
