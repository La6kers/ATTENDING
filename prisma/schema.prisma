// ATTENDING AI - Complete Database Schema
// Production: MS SQL Server (Azure SQL) with encryption at rest
// Development: MS SQL Server 2022 via docker-compose
// 
// HIPAA Requirements:
// - 164.312(a)(2)(iv) - Encryption and Decryption
//   Production database MUST have Transparent Data Encryption (TDE) enabled
// - 164.530(j) - 6-year minimum record retention
//   All PHI-containing models use soft-delete (deletedAt/deletedBy)
//   Middleware in apps/shared/lib/softDeleteMiddleware.ts
//   auto-filters deleted records and converts deletes to soft-deletes
//
// SQL Server Note: All relations use onDelete/onUpdate: NoAction to avoid
// "multiple cascade paths" errors. Cascading deletes are handled by
// application-level soft-delete middleware instead.
//
// Run: npx prisma db push (development)
// Production: npx prisma migrate deploy

generator client {
  provider = "prisma-client-js"
}

// MS SQL Server for all environments.
// Local dev: docker-compose provides SQL Server 2022 on port 1433
// Production: Azure SQL with TDE enabled
datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// NOTE: Prisma does not support native enums on SQL Server.
// All enum-like fields use String with application-level validation.
// Canonical values are defined in @attending/shared types.

// ============== ORGANIZATIONS (Multi-Tenant) ==============

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  type         String   @default("CLINIC")
  npi          String?
  taxId        String?
  address      String?
  city         String?
  state        String?
  zipCode      String?
  phone        String?
  faxNumber    String?
  website      String?
  ehrVendor    String?
  fhirEndpoint String?
  tier         String   @default("standard")
  isActive     Boolean  @default(true)
  settings     String?  @db.NVarChar(Max)
  featureFlags String?  @db.NVarChar(Max)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users              User[]
  patients           Patient[]
  encounters         Encounter[]
  labOrders          LabOrder[]
  imagingOrders      ImagingOrder[]
  medicationOrders   MedicationOrder[]
  referrals          Referral[]
  assessments        PatientAssessment[]
  apiKeys            ApiKey[]
  webhooks           WebhookSubscription[]
  integrations       IntegrationConnection[]
  auditLogs          AuditLog[]
  clinicalNotes      ClinicalNote[]
  treatmentPlans     TreatmentPlan[]
  clinicEnvironments ClinicEnvironment[]
  allergies          Allergy[]
  conditions         Condition[]
  medications        Medication[]
  vitalSigns         VitalSign[]
  labResults         LabResult[]
  imagingResults     ImagingResult[]
  emergencyEvents    EmergencyEvent[]
  clinicalImages     ClinicalImage[]
  populationFlags    PatientPopulationFlag[]
  usageRecords       UsageRecord[]

  @@index([slug])
  @@index([isActive])
  @@index([tier])
}

// ============== AUTHENTICATION & USERS ==============

model User {
  id                  String    @id @default(cuid())
  organizationId      String?
  email               String    @unique
  emailVerified       DateTime?
  name                String?
  image               String?
  password            String?
  role                String    @default("PROVIDER")
  specialty           String?
  npi                 String?   @unique
  deaNumber           String?
  department          String?
  phone               String?
  isActive            Boolean   @default(true)
  mfaEnabled          Boolean   @default(false)
  mfaSecret           String?
  lastLoginAt         DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization        Organization?           @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  accounts            Account[]
  sessions            Session[]
  encounters          Encounter[]             @relation("ProviderEncounters")
  labOrders           LabOrder[]
  imagingOrders       ImagingOrder[]
  medicationOrders    MedicationOrder[]
  referrals           Referral[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  assignedAssessments PatientAssessment[]     @relation("AssignedProvider")
  environmentSession  UserEnvironmentSession?
  reviewedImages      ClinicalImage[]

  @@index([email])
  @@index([npi])
  @@index([role])
  @@index([isActive])
  @@index([organizationId])
}

model Account {
  id                String    @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?   @db.NVarChar(Max)
  access_token      String?   @db.NVarChar(Max)
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?   @db.NVarChar(Max)
  session_state     String?
  deletedAt         DateTime?
  deletedBy         String?

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String    @id @default(cuid())
  sessionToken String    @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  deletedAt    DateTime?
  deletedBy    String?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============== PATIENTS ==============

model Patient {
  id                  String    @id @default(cuid())
  organizationId      String
  mrn                 String
  firstName           String
  lastName            String
  middleName          String?
  dateOfBirth         DateTime
  // Legacy fields (kept for backward compatibility)
  gender              String?
  sex                 String?
  // Inclusive demographics — replaces gender/sex for new records
  legalName           String? // Full legal name (insurance/billing only)
  chosenName          String? // Preferred display name — shown INSTEAD of legalName when present
  sexAssignedAtBirth  String? // MALE, FEMALE, INTERSEX, UNKNOWN
  genderIdentity      String? // MALE, FEMALE, NON_BINARY, TRANSGENDER_MALE, TRANSGENDER_FEMALE, GENDERQUEER, TWO_SPIRIT, OTHER, PREFER_NOT_TO_SAY
  pronouns            String? // "he/him", "she/her", "they/them", "ze/zir", etc.
  sexualOrientation   String? // For preventive care screening relevance
  // Pregnancy tracking
  pregnancyStatus     String?   @default("NOT_APPLICABLE") // NOT_PREGNANT, PREGNANT, POSTPARTUM, UNKNOWN, NOT_APPLICABLE
  gestationalAgeWeeks Int? // Current gestational age in weeks (nullable)
  estimatedDueDate    DateTime? // EDD for pregnant patients
  // Contact & demographics
  email               String?
  phone               String?
  address             String?
  city                String?
  state               String?
  zipCode             String?
  emergencyContact    String?
  emergencyPhone      String?
  insuranceProvider   String?
  insurancePolicyNum  String?
  preferredLanguage   String    @default("en")
  // Communication preferences
  communicationNeeds  String?   @db.NVarChar(Max) // JSON: hearing impaired, interpreter needed, literacy level, etc.
  isActive            Boolean   @default(true)
  deletedAt           DateTime?
  deletedBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  encounters       Encounter[]
  allergies        Allergy[]
  conditions       Condition[]
  medications      Medication[]
  vitalSigns       VitalSign[]
  labOrders        LabOrder[]
  labResults       LabResult[]
  imagingOrders    ImagingOrder[]
  imagingResults   ImagingResult[]
  medicationOrders MedicationOrder[]
  referrals        Referral[]
  assessments      PatientAssessment[]
  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  emergencyEvents  EmergencyEvent[]
  treatmentPlans   TreatmentPlan[]
  fhirLabResults   FhirLabResult[]
  fhirConditions   FhirCondition[]
  fhirMedications  FhirMedication[]
  fhirVitalSigns   FhirVitalSign[]
  clinicalNotes    ClinicalNote[]
  populationFlags  PatientPopulationFlag[]
  clinicalImages   ClinicalImage[]

  @@unique([organizationId, mrn])
  @@index([mrn])
  @@index([lastName, firstName])
  @@index([dateOfBirth])
  @@index([isActive])
  @@index([deletedAt])
  @@index([organizationId])
  @@index([genderIdentity])
  @@index([pregnancyStatus])
}

// ============== CLINICAL ENCOUNTERS ==============

model Encounter {
  id             String    @id @default(cuid())
  organizationId String
  patientId      String
  providerId     String
  facilityId     String?
  encounterType  String
  status         String    @default("IN_PROGRESS")
  chiefComplaint String?
  startTime      DateTime  @default(now())
  endTime        DateTime?
  notes          String?   @db.NVarChar(Max)
  diagnosis      String?   @db.NVarChar(Max)
  deletedAt      DateTime?
  deletedBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient          Patient           @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  provider         User              @relation("ProviderEncounters", fields: [providerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  labOrders        LabOrder[]
  imagingOrders    ImagingOrder[]
  medicationOrders MedicationOrder[]
  referrals        Referral[]
  vitalSigns       VitalSign[]
  treatmentPlans   TreatmentPlan[]
  clinicalNotes    ClinicalNote[]
  clinicalImages   ClinicalImage[]

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([startTime])
  @@index([deletedAt])
  @@index([organizationId])
  @@index([providerId, status])
  @@index([patientId, startTime])
  @@index([providerId, status, startTime])
  @@index([patientId, createdAt])
  @@index([organizationId, createdAt])
}

// ============== ALLERGIES ==============

model Allergy {
  id             String    @id @default(cuid())
  patientId      String
  organizationId String
  allergen       String
  reaction   String?
  severity   String?
  onsetDate  DateTime?
  status     String    @default("ACTIVE")
  verifiedAt DateTime?
  notes      String?   @db.NVarChar(Max)
  deletedAt  DateTime?
  deletedBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([patientId])
  @@index([allergen])
  @@index([deletedAt])
  @@index([organizationId])
}

// ============== CONDITIONS / DIAGNOSES ==============

model Condition {
  id             String    @id @default(cuid())
  patientId      String
  organizationId String
  name           String    @default("")
  icdCode       String    @default("")
  description   String    @default("")
  severity      String?
  status        String    @default("ACTIVE")
  onsetDate     DateTime?
  abatementDate DateTime?
  isPrimary     Boolean   @default(false)
  notes         String?   @db.NVarChar(Max)
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([patientId])
  @@index([icdCode])
  @@index([status])
  @@index([deletedAt])
  @@index([organizationId])
}

// ============== MEDICATIONS ==============

model Medication {
  id             String    @id @default(cuid())
  patientId      String
  organizationId String
  name           String
  genericName  String?
  rxnormCode   String?
  ndcCode      String?
  dose         String?
  frequency    String?
  route        String?
  status       String    @default("ACTIVE")
  startDate    DateTime?
  endDate      DateTime?
  prescribedBy String?
  pharmacy     String?
  notes        String?   @db.NVarChar(Max)
  deletedAt    DateTime?
  deletedBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([patientId])
  @@index([name])
  @@index([status])
  @@index([deletedAt])
  @@index([organizationId])
}

// ============== VITAL SIGNS ==============

model VitalSign {
  id                     String    @id @default(cuid())
  patientId              String
  organizationId         String
  encounterId            String?
  heartRate              Int?
  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  respiratoryRate        Int?
  temperature            Float?
  temperatureUnit        String    @default("F")
  oxygenSaturation       Float?
  weight                 Float?
  weightUnit             String    @default("lbs")
  height                 Float?
  heightUnit             String    @default("in")
  painLevel              Int?
  bloodGlucose           Float?
  notes                  String?   @db.NVarChar(Max)
  recordedAt             DateTime  @default(now())
  recordedBy             String?
  deletedAt              DateTime?
  deletedBy              String?
  createdAt              DateTime  @default(now())

  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  encounter    Encounter?   @relation(fields: [encounterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([patientId])
  @@index([encounterId])
  @@index([recordedAt])
  @@index([deletedAt])
  @@index([organizationId])
}

// ============== LAB ORDERS ==============

model LabOrder {
  id                  String    @id @default(cuid())
  organizationId      String
  patientId           String
  providerId          String
  encounterId         String?
  orderNumber         String    @unique
  status              String    @default("PENDING")
  priority            String    @default("ROUTINE")
  tests               String    @db.NVarChar(Max)
  diagnosis           String?   @db.NVarChar(Max)
  indication          String?
  specialInstructions String?   @db.NVarChar(Max)
  specimenType        String?
  collectionDate      DateTime?
  fasting             Boolean   @default(false)
  orderedAt           DateTime  @default(now())
  completedAt         DateTime?
  deletedAt           DateTime?
  deletedBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  provider     User          @relation(fields: [providerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  encounter    Encounter?    @relation(fields: [encounterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  results      LabResult[]

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([orderedAt])
  @@index([deletedAt])
  @@index([organizationId])
  @@index([providerId, status])
  @@index([patientId, orderedAt])
  @@index([patientId, createdAt])
  @@index([organizationId, createdAt])
}

model LabResult {
  id             String    @id @default(cuid())
  patientId      String
  organizationId String
  labOrderId     String?
  testCode       String
  testName       String
  loincCode      String?
  value          String
  unit           String?
  referenceRange String?
  interpretation String?
  status         String    @default("FINAL")
  performedAt    DateTime?
  reportedAt     DateTime  @default(now())
  notes          String?   @db.NVarChar(Max)
  deletedAt      DateTime?
  deletedBy      String?
  createdAt      DateTime  @default(now())

  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  labOrder     LabOrder?    @relation(fields: [labOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([patientId])
  @@index([labOrderId])
  @@index([testCode])
  @@index([interpretation])
  @@index([deletedAt])
  @@index([organizationId])
}

// ============== IMAGING ORDERS ==============

model ImagingOrder {
  id                  String    @id @default(cuid())
  organizationId      String
  patientId           String
  providerId          String
  encounterId         String?
  orderNumber         String    @unique
  status              String    @default("PENDING")
  priority            String    @default("ROUTINE")
  studyType           String
  studyName           String
  bodyPart            String
  laterality          String?
  indication          String    @db.NVarChar(Max)
  clinicalHistory     String?   @db.NVarChar(Max)
  contrast            Boolean   @default(false)
  contrastType        String?
  specialInstructions String?   @db.NVarChar(Max)
  diagnosis           String?   @db.NVarChar(Max)
  scheduledDate       DateTime?
  orderedAt           DateTime  @default(now())
  completedAt         DateTime?
  deletedAt           DateTime?
  deletedBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient      Patient         @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  provider     User            @relation(fields: [providerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  encounter    Encounter?      @relation(fields: [encounterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  results      ImagingResult[]

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([orderedAt])
  @@index([deletedAt])
  @@index([organizationId])
  @@index([patientId, createdAt])
  @@index([organizationId, createdAt])
}

model ImagingResult {
  id             String    @id @default(cuid())
  patientId      String
  organizationId String
  imagingOrderId String?
  studyType      String
  studyName      String
  findings       String    @db.NVarChar(Max)
  impression     String?   @db.NVarChar(Max)
  radiologistId  String?
  status         String    @default("FINAL")
  performedAt    DateTime?
  reportedAt     DateTime  @default(now())
  deletedAt      DateTime?
  deletedBy      String?
  createdAt      DateTime  @default(now())

  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  imagingOrder ImagingOrder? @relation(fields: [imagingOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([patientId])
  @@index([imagingOrderId])
  @@index([deletedAt])
  @@index([organizationId])
}

// ============== MEDICATION ORDERS ==============

model MedicationOrder {
  id                  String    @id @default(cuid())
  organizationId      String
  patientId           String
  providerId          String
  encounterId         String?
  orderNumber         String    @unique
  status              String    @default("ACTIVE")
  medicationName      String
  genericName         String?
  rxnormCode          String?
  ndcCode             String?
  dose                String
  doseUnit            String?
  frequency           String
  route               String
  duration            String?
  quantity            Int?
  refills             Int       @default(0)
  indication          String    @db.NVarChar(Max)
  instructions        String?   @db.NVarChar(Max)
  isControlled        Boolean   @default(false)
  deaSchedule         String?
  dispenseAsWritten   Boolean   @default(false)
  substitutionAllowed Boolean   @default(true)
  priorAuthRequired   Boolean   @default(false)
  priorAuthStatus     String?
  diagnosis           String?   @db.NVarChar(Max)
  pharmacy            String?
  pharmacyNpi         String?
  orderedAt           DateTime  @default(now())
  discontinuedAt      DateTime?
  discontinuedReason  String?
  deletedAt           DateTime?
  deletedBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  provider     User          @relation(fields: [providerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  encounter    Encounter?    @relation(fields: [encounterId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([isControlled])
  @@index([orderedAt])
  @@index([deletedAt])
  @@index([organizationId])
  @@index([patientId, createdAt])
  @@index([organizationId, createdAt])
}

// ============== PHARMACIES & PRICING ==============

model Pharmacy {
  id          String   @id @default(cuid())
  name        String
  chain       String?
  address     String
  city        String
  state       String
  zipCode     String
  phone       String
  fax         String?
  npi         String?
  latitude    Float?
  longitude   Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prices      PharmacyPrice[]

  @@index([zipCode])
  @@index([chain])
  @@index([isActive])
}

model PharmacyPrice {
  id              String   @id @default(cuid())
  pharmacyId      String
  medicationName  String
  strength        String
  form            String
  quantity        Int
  cashPrice       Float
  source          String   @default("manual")
  lastVerified    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  pharmacy        Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@unique([pharmacyId, medicationName, strength, form, quantity])
  @@index([medicationName, strength, form, quantity])
  @@index([pharmacyId])
  @@index([lastVerified])
}

// ============== REFERRALS ==============

model Referral {
  id                String    @id @default(cuid())
  organizationId    String
  patientId         String
  providerId        String
  encounterId       String?
  orderNumber       String    @unique
  status            String    @default("PENDING")
  urgency           String    @default("ROUTINE")
  specialty         String
  subspecialty      String?
  reason            String    @db.NVarChar(Max)
  clinicalSummary   String?   @db.NVarChar(Max)
  specificQuestions String?   @db.NVarChar(Max)
  preferredProvider String?
  preferredFacility String?
  diagnosis         String?   @db.NVarChar(Max)
  insurancePreAuth  Boolean   @default(false)
  preAuthStatus     String?
  scheduledDate     DateTime?
  orderedAt         DateTime  @default(now())
  completedAt       DateTime?
  consultNote       String?   @db.NVarChar(Max)
  deletedAt         DateTime?
  deletedBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  provider     User          @relation(fields: [providerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  encounter    Encounter?    @relation(fields: [encounterId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([specialty])
  @@index([deletedAt])
  @@index([organizationId])
  @@index([patientId, createdAt])
  @@index([organizationId, createdAt])
}

// ============== PATIENT ASSESSMENTS (COMPASS) ==============

model PatientAssessment {
  id                 String    @id @default(cuid())
  organizationId     String
  patientId          String
  assignedProviderId String?
  sessionId          String    @unique
  status             String    @default("IN_PROGRESS")
  phase              String    @default("GREETING")
  chiefComplaint     String?   @db.NVarChar(Max)
  symptoms           String?   @db.NVarChar(Max)
  hpiNarrative       String?   @db.NVarChar(Max)
  reviewOfSystems    String?   @db.NVarChar(Max)
  medicalHistory     String?   @db.NVarChar(Max)
  medications        String?   @db.NVarChar(Max)
  allergies          String?   @db.NVarChar(Max)
  vitalSigns         String?   @db.NVarChar(Max)
  triageLevel        String?
  redFlagsDetected   String?   @db.NVarChar(Max)
  aiSummary          String?   @db.NVarChar(Max)
  aiDifferential     String?   @db.NVarChar(Max)
  conversation       String?   @db.NVarChar(Max)
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  lastActivityAt     DateTime  @default(now())
  deletedAt          DateTime?
  deletedBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient          Patient          @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedProvider User?            @relation("AssignedProvider", fields: [assignedProviderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  emergencyEvents  EmergencyEvent[]
