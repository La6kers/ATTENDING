  dose            String?
  status          String?
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([patientId])
  @@index([fhirId])
}

model FhirVitalSign {
  id              String   @id @default(cuid())
  patientId       String
  fhirId          String   @unique
  fhirServerId    String
  resourceType    String   @default("Observation")
  rawResource     String   @db.NVarChar(Max)
  vitalType       String?
  value           String?
  unit            String?
  effectiveDate   DateTime?
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

