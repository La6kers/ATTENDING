  testName        String?
  value           String?
  unit            String?
  interpretation  String?
  effectiveDate   DateTime?
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([patientId])
  @@index([fhirId])
  @@index([fhirServerId])
}

model FhirCondition {
  id              String   @id @default(cuid())
  patientId       String
  fhirId          String   @unique
  fhirServerId    String
  resourceType    String   @default("Condition")
  rawResource     String   @db.NVarChar(Max)
  icdCode         String?
  description     String?
  status          String?
  onsetDate       DateTime?
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([patientId])
  @@index([fhirId])
}

model FhirMedication {
  id              String   @id @default(cuid())
