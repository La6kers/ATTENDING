// ============== DEAD LETTER QUEUE ==============

model DeadLetterEntry {
  id             String    @id @default(cuid())
  type           String
  status         String    @default("pending")
  payload        String    @db.NVarChar(Max)
  destination    String
  error          String    @db.NVarChar(Max)
  attempts       Int       @default(0)
  originalId     String?
  organizationId String?
  lastStatusCode Int?
  metadata       String?   @db.NVarChar(Max)
  replayedAt     DateTime?
  replayResult   String?   @db.NVarChar(Max)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([organizationId])
  @@index([createdAt])
  @@index([status, type])
}

// ============== CLINICAL PROTOCOLS ==============

model ClinicalProtocol {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String   @db.NVarChar(Max)
  version       String
  category      String
  triggerRules  String   @db.NVarChar(Max)
  actions       String   @db.NVarChar(Max)
  evidenceLevel String?
  guidelineRef  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

// ============== RED FLAG RULES ==============

model RedFlagRule {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String   @db.NVarChar(Max)
  category        String
  severity        String
  triggerCriteria String   @db.NVarChar(Max)
  vitalThresholds String?  @db.NVarChar(Max)
  icdCodes        String?  @db.NVarChar(Max)
  recommendedAction String @db.NVarChar(Max)
  timeframe       String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([severity])
  @@index([isActive])
}
