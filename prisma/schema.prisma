// ATTENDING AI - Complete Database Schema
// Production: PostgreSQL with encryption at rest
// Development: PostgreSQL via docker-compose
// 
// HIPAA Requirements:
// - 164.312(a)(2)(iv) - Encryption and Decryption
//   Production database MUST have encryption at rest enabled
// - 164.530(j) - 6-year minimum record retention
//   All PHI-containing models use soft-delete (deletedAt/deletedBy)
//   Middleware in apps/shared/lib/softDeleteMiddleware.ts
//   auto-filters deleted records and converts deletes to soft-deletes
//
// Run: npx prisma migrate dev --name init
// Production: npx prisma migrate deploy

generator client {
  provider = "prisma-client-js"
}

// PostgreSQL for all environments.
// Local dev: docker-compose provides postgres on port 5432
// Production: DATABASE_URL="postgresql://user:pass@host:5432/attending?sslmode=require"
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== ENUMS ==============

enum UserRole {
  ADMIN
  PROVIDER
  NURSE
  STAFF
  PATIENT
  SYSTEM
}

enum OrderStatus {
  PENDING
  COLLECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ACTIVE
  ON_HOLD
  SCHEDULED
  SENT
  DISCONTINUED
}

enum OrderPriority {
  STAT
  ASAP
  URGENT
  ROUTINE
  TIMED
  ELECTIVE
}

enum EncounterStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AssessmentStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
  EMERGENCY
}

enum EncounterType {
  OFFICE
  TELEHEALTH
  EMERGENCY
  INPATIENT
}

// ============== ORGANIZATIONS (Multi-Tenant) ==============

model Organization {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique // URL-safe identifier
  type            String    @default("CLINIC") // CLINIC, HOSPITAL, HEALTH_SYSTEM, PRACTICE
  npi             String?   // Organization NPI
  taxId           String?   // EIN (encrypted)
  address         String?
  city            String?
  state           String?
  zipCode         String?
  phone           String?
  faxNumber       String?
  website         String?
  ehrVendor       String?   // EPIC, CERNER, ALLSCRIPTS, etc.
  fhirEndpoint    String?   // Base FHIR URL for this org's EHR
  tier            String    @default("standard") // free, standard, enterprise
  isActive        Boolean   @default(true)
  settings        String?   // JSON: org-specific configuration
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  users           User[]
  patients        Patient[]
  encounters      Encounter[]
  labOrders       LabOrder[]
  imagingOrders   ImagingOrder[]
  medicationOrders MedicationOrder[]
  referrals       Referral[]
  assessments     PatientAssessment[]
  apiKeys         ApiKey[]
  webhooks        WebhookSubscription[]
  integrations    IntegrationConnection[]
  auditLogs       AuditLog[]
  clinicalNotes   ClinicalNote[]
  treatmentPlans  TreatmentPlan[]

  @@index([slug])
  @@index([isActive])
  @@index([tier])
}

// ============== AUTHENTICATION & USERS ==============

model User {
  id              String    @id @default(cuid())
  organizationId  String?
  email           String    @unique
  emailVerified   DateTime?
  name            String?
  image           String?
  password        String?   // Hashed with bcrypt, never stored plain
  role            String    @default("PROVIDER") // ADMIN, PROVIDER, NURSE, STAFF, PATIENT
  specialty     String?
  npi           String?   @unique // National Provider Identifier
  deaNumber     String?   // DEA number for controlled substances
  department    String?
  phone         String?
  isActive      Boolean   @default(true)
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?   // Encrypted TOTP secret
  lastLoginAt   DateTime?
  failedLoginAttempts Int @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  organization        Organization? @relation(fields: [organizationId], references: [id])
  accounts            Account[]
  sessions            Session[]
  encounters          Encounter[]        @relation("ProviderEncounters")
  labOrders           LabOrder[]
  imagingOrders       ImagingOrder[]
  medicationOrders    MedicationOrder[]
  referrals           Referral[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  assignedAssessments PatientAssessment[] @relation("AssignedProvider")

  @@index([email])
  @@index([npi])
  @@index([role])
  @@index([isActive])
  @@index([organizationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============== PATIENTS ==============

model Patient {
  id                 String    @id @default(cuid())
  organizationId     String?
  mrn                String    @unique // Medical Record Number
  firstName          String
  lastName           String
  middleName         String?
  dateOfBirth        DateTime
  gender             String?
  sex                String?
  email              String?
  phone              String?
  address            String?
  city               String?
  state              String?
  zipCode            String?
  emergencyContact   String?
  emergencyPhone     String?
  insuranceProvider  String?
  insurancePolicyNum String?
  preferredLanguage  String    @default("en")
  isActive           Boolean   @default(true)
  // HIPAA soft-delete: 164.530(j) - 6-year retention minimum
  deletedAt          DateTime?
  deletedBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  encounters        Encounter[]
  allergies         Allergy[]
  conditions        Condition[]
  medications       Medication[]
  vitalSigns        VitalSign[]
  labOrders         LabOrder[]
  labResults        LabResult[]
  imagingOrders     ImagingOrder[]
  imagingResults    ImagingResult[]
  medicationOrders  MedicationOrder[]
  referrals         Referral[]
  assessments       PatientAssessment[]
  organization      Organization? @relation(fields: [organizationId], references: [id])
  emergencyEvents   EmergencyEvent[]
  treatmentPlans    TreatmentPlan[]
  fhirLabResults    FhirLabResult[]
  fhirConditions    FhirCondition[]
  fhirMedications   FhirMedication[]
  fhirVitalSigns    FhirVitalSign[]
  clinicalNotes     ClinicalNote[]

  @@index([mrn])
  @@index([lastName, firstName])
  @@index([dateOfBirth])
  @@index([isActive])
  @@index([deletedAt])
  @@index([organizationId])
}

// ============== CLINICAL ENCOUNTERS ==============

model Encounter {
  id              String    @id @default(cuid())
  organizationId  String?
  patientId       String
  providerId      String
  facilityId      String?
  encounterType   String    // OFFICE, TELEHEALTH, EMERGENCY, INPATIENT
  status          String    @default("IN_PROGRESS") // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED
  chiefComplaint  String?
  startTime       DateTime  @default(now())
  endTime         DateTime?
  notes           String?
  diagnosis       String?   // JSON array of diagnosis codes
  // HIPAA soft-delete
  deletedAt       DateTime?
  deletedBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization       Organization? @relation(fields: [organizationId], references: [id])
  patient          Patient            @relation(fields: [patientId], references: [id], onDelete: Restrict)
  provider         User               @relation("ProviderEncounters", fields: [providerId], references: [id], onDelete: Restrict)
  labOrders        LabOrder[]
  imagingOrders    ImagingOrder[]
  medicationOrders MedicationOrder[]
  referrals        Referral[]
  vitalSigns       VitalSign[]
  treatmentPlans   TreatmentPlan[]
  clinicalNotes    ClinicalNote[]

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([startTime])
  @@index([deletedAt])
  @@index([organizationId])
  @@index([providerId, status])          // Provider dashboard: active encounters
  @@index([patientId, startTime])        // Patient timeline queries
  @@index([providerId, status, startTime]) // Sorted provider queue
}

// ============== ALLERGIES ==============

model Allergy {
  id         String    @id @default(cuid())
  patientId  String
  allergen   String
  reaction   String?
  severity   String?   // MILD, MODERATE, SEVERE, LIFE_THREATENING
  onsetDate  DateTime?
  status     String    @default("ACTIVE") // ACTIVE, INACTIVE, RESOLVED
  verifiedAt DateTime?
  notes      String?
  // HIPAA soft-delete: 164.530(j)
  deletedAt  DateTime?
  deletedBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([allergen])
  @@index([deletedAt])
}

// ============== CONDITIONS / DIAGNOSES ==============

model Condition {
  id            String    @id @default(cuid())
  patientId     String
  icdCode       String
  description   String
  status        String    @default("ACTIVE") // ACTIVE, RESOLVED, INACTIVE
  onsetDate     DateTime?
  abatementDate DateTime?
  isPrimary     Boolean   @default(false)
  notes         String?
  // HIPAA soft-delete: 164.530(j)
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([icdCode])
  @@index([status])
  @@index([deletedAt])
}

// ============== MEDICATIONS ==============

model Medication {
  id            String    @id @default(cuid())
  patientId     String
  name          String
  genericName   String?
  rxnormCode    String?
  ndcCode       String?
  dose          String?
  frequency     String?
  route         String?
  status        String    @default("ACTIVE") // ACTIVE, COMPLETED, DISCONTINUED, ON_HOLD
  startDate     DateTime?
  endDate       DateTime?
  prescribedBy  String?
  pharmacy      String?
  notes         String?
  // HIPAA soft-delete: 164.530(j)
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([name])
  @@index([status])
  @@index([deletedAt])
}

// ============== VITAL SIGNS ==============

model VitalSign {
  id                    String    @id @default(cuid())
  patientId             String
  encounterId           String?
  heartRate             Int?
  bloodPressureSystolic Int?
  bloodPressureDiastolic Int?
  respiratoryRate       Int?
  temperature           Float?
  temperatureUnit       String    @default("F")
  oxygenSaturation      Float?
  weight                Float?
  weightUnit            String    @default("lbs")
  height                Float?
  heightUnit            String    @default("in")
  painLevel             Int?
  bloodGlucose          Float?
  notes                 String?
  recordedAt            DateTime  @default(now())
  recordedBy            String?
  // HIPAA soft-delete: 164.530(j)
  deletedAt             DateTime?
  deletedBy             String?
  createdAt             DateTime  @default(now())

  patient   Patient    @relation(fields: [patientId], references: [id])
  encounter Encounter? @relation(fields: [encounterId], references: [id])

  @@index([patientId])
  @@index([encounterId])
  @@index([recordedAt])
  @@index([deletedAt])
}

// ============== LAB ORDERS ==============

model LabOrder {
  id                  String    @id @default(cuid())
  organizationId      String?
  patientId           String
  providerId          String
  encounterId         String?
  orderNumber         String    @unique
  status              String    @default("PENDING") // PENDING, COLLECTED, IN_PROGRESS, COMPLETED, CANCELLED
  priority            String    @default("ROUTINE") // STAT, ASAP, ROUTINE, TIMED
  tests               String    // JSON array of ordered tests
  diagnosis           String?   // JSON array of diagnosis codes
  indication          String?
  specialInstructions String?
  specimenType        String?
  collectionDate      DateTime?
  fasting             Boolean   @default(false)
  orderedAt           DateTime  @default(now())
  completedAt         DateTime?
  // HIPAA soft-delete
  deletedAt           DateTime?
  deletedBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  patient   Patient     @relation(fields: [patientId], references: [id], onDelete: Restrict)
  provider  User        @relation(fields: [providerId], references: [id], onDelete: Restrict)
  encounter Encounter?  @relation(fields: [encounterId], references: [id])
  results   LabResult[]

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([orderedAt])
  @@index([deletedAt])
  @@index([organizationId])
  @@index([providerId, status])    // Provider pending orders dashboard
  @@index([patientId, orderedAt])  // Patient lab history timeline
}

model LabResult {
  id             String    @id @default(cuid())
  patientId      String
  labOrderId     String?
  testCode       String
  testName       String
  loincCode      String?
  value          String
  unit           String?
  referenceRange String?
  interpretation String?   // NORMAL, HIGH, LOW, CRITICAL_HIGH, CRITICAL_LOW
  status         String    @default("FINAL") // PRELIMINARY, FINAL, CORRECTED
  performedAt    DateTime?
  reportedAt     DateTime  @default(now())
  notes          String?
  // HIPAA soft-delete: 164.530(j)
  deletedAt      DateTime?
  deletedBy      String?
  createdAt      DateTime  @default(now())

  patient  Patient   @relation(fields: [patientId], references: [id])
  labOrder LabOrder? @relation(fields: [labOrderId], references: [id])

  @@index([patientId])
  @@index([labOrderId])
  @@index([testCode])
  @@index([interpretation])
  @@index([deletedAt])
}

// ============== IMAGING ORDERS ==============

model ImagingOrder {
  id                  String    @id @default(cuid())
  organizationId      String?
  patientId           String
  providerId          String
  encounterId         String?
  orderNumber         String    @unique
  status              String    @default("PENDING") // PENDING, SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED
  priority            String    @default("ROUTINE") // STAT, URGENT, ROUTINE
  studyType           String    // X-RAY, CT, MRI, ULTRASOUND, etc.
  studyName           String
  bodyPart            String
  laterality          String?   // LEFT, RIGHT, BILATERAL
  indication          String
  clinicalHistory     String?
  contrast            Boolean   @default(false)
  contrastType        String?
  specialInstructions String?
  diagnosis           String?   // JSON array
  scheduledDate       DateTime?
  orderedAt           DateTime  @default(now())
  completedAt         DateTime?
  // HIPAA soft-delete: 164.530(j)
  deletedAt           DateTime?
  deletedBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  patient   Patient         @relation(fields: [patientId], references: [id], onDelete: Restrict)
  provider  User            @relation(fields: [providerId], references: [id], onDelete: Restrict)
  encounter Encounter?      @relation(fields: [encounterId], references: [id])
  results   ImagingResult[]

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([orderedAt])
  @@index([deletedAt])
  @@index([organizationId])
}

model ImagingResult {
  id             String    @id @default(cuid())
  patientId      String
  imagingOrderId String?
  studyType      String
  studyName      String
  findings       String
  impression     String?
  radiologistId  String?
  status         String    @default("FINAL") // PRELIMINARY, FINAL, ADDENDUM
  performedAt    DateTime?
  reportedAt     DateTime  @default(now())
  // HIPAA soft-delete: 164.530(j)
  deletedAt      DateTime?
  deletedBy      String?
  createdAt      DateTime  @default(now())

  patient      Patient       @relation(fields: [patientId], references: [id])
  imagingOrder ImagingOrder? @relation(fields: [imagingOrderId], references: [id])

  @@index([patientId])
  @@index([imagingOrderId])
  @@index([deletedAt])
}

// ============== MEDICATION ORDERS ==============

model MedicationOrder {
  id                   String    @id @default(cuid())
  organizationId       String?
  patientId            String
  providerId           String
  encounterId          String?
  orderNumber          String    @unique
  status               String    @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED, ON_HOLD
  medicationName       String
  genericName          String?
  rxnormCode           String?
  ndcCode              String?
  dose                 String
  doseUnit             String?
  frequency            String
  route                String
  duration             String?
  quantity             Int?
  refills              Int       @default(0)
  indication           String
  instructions         String?
  isControlled         Boolean   @default(false)
  deaSchedule          String?   // II, III, IV, V
  dispenseAsWritten    Boolean   @default(false)
  substitutionAllowed  Boolean   @default(true)
  priorAuthRequired    Boolean   @default(false)
  priorAuthStatus      String?   // PENDING, APPROVED, DENIED
  diagnosis            String?   // JSON array
  pharmacy             String?
  pharmacyNpi          String?
  orderedAt            DateTime  @default(now())
  discontinuedAt       DateTime?
  discontinuedReason   String?
  // HIPAA soft-delete
  deletedAt            DateTime?
  deletedBy            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  patient   Patient    @relation(fields: [patientId], references: [id], onDelete: Restrict)
  provider  User       @relation(fields: [providerId], references: [id], onDelete: Restrict)
  encounter Encounter? @relation(fields: [encounterId], references: [id])

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([isControlled])
  @@index([orderedAt])
  @@index([deletedAt])
  @@index([organizationId])
}

// ============== REFERRALS ==============

model Referral {
  id                String    @id @default(cuid())
  organizationId    String?
  patientId         String
  providerId        String
  encounterId       String?
  orderNumber       String    @unique
  status            String    @default("PENDING") // PENDING, SENT, SCHEDULED, COMPLETED, CANCELLED
  urgency           String    @default("ROUTINE") // STAT, URGENT, ROUTINE, ELECTIVE
  specialty         String
  subspecialty      String?
  reason            String
  clinicalSummary   String?
  specificQuestions String?
  preferredProvider String?
  preferredFacility String?
  diagnosis         String?   // JSON array
  insurancePreAuth  Boolean   @default(false)
  preAuthStatus     String?
  scheduledDate     DateTime?
  orderedAt         DateTime  @default(now())
  completedAt       DateTime?
  consultNote       String?
  // HIPAA soft-delete: 164.530(j)
  deletedAt         DateTime?
  deletedBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  patient   Patient    @relation(fields: [patientId], references: [id], onDelete: Restrict)
  provider  User       @relation(fields: [providerId], references: [id], onDelete: Restrict)
  encounter Encounter? @relation(fields: [encounterId], references: [id])

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([specialty])
  @@index([deletedAt])
  @@index([organizationId])
}

// ============== PATIENT ASSESSMENTS (COMPASS) ==============

model PatientAssessment {
  id                 String    @id @default(cuid())
  organizationId     String?
  patientId          String
  assignedProviderId String?
  sessionId          String    @unique
  status             String    @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, ABANDONED, EMERGENCY
  phase              String    @default("GREETING")
  chiefComplaint     String?
  symptoms           String?   // JSON array
  hpiNarrative       String?
  reviewOfSystems    String?   // JSON object
  medicalHistory     String?   // JSON array
  medications        String?   // JSON array
  allergies          String?   // JSON array
  vitalSigns         String?   // JSON object
  triageLevel        String?   // ESI 1-5 or custom
  redFlagsDetected   String?   // JSON array of detected red flags
  aiSummary          String?
  aiDifferential     String?   // JSON array of differential diagnoses
  conversation       String?   // JSON array of chat messages
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  lastActivityAt     DateTime  @default(now())
  // HIPAA soft-delete
  deletedAt          DateTime?
  deletedBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization    Organization?    @relation(fields: [organizationId], references: [id])
  patient          Patient          @relation(fields: [patientId], references: [id], onDelete: Restrict)
  assignedProvider User?            @relation("AssignedProvider", fields: [assignedProviderId], references: [id])
  emergencyEvents  EmergencyEvent[]

  @@index([patientId])
  @@index([assignedProviderId])
  @@index([status])
  @@index([sessionId])
  @@index([deletedAt])
  @@index([organizationId])
}

// ============== EMERGENCY EVENTS ==============

model EmergencyEvent {
  id                String    @id @default(cuid())
  patientId         String
  assessmentId      String?
  eventType         String    // RED_FLAG, CRASH_DETECTION, MANUAL_TRIGGER
  severity          String    // CRITICAL, HIGH, MODERATE
  description       String
  triggeredBy       String    // SYSTEM, PATIENT, PROVIDER
  symptoms          String?   // JSON array
  vitalSigns        String?   // JSON object
  location          String?   // GPS coordinates or address
  acknowledgedAt    DateTime?
  acknowledgedBy    String?
  resolvedAt        DateTime?
  resolvedBy        String?
  resolution        String?
  notificationsSent String?   // JSON array of notifications sent
  // HIPAA soft-delete: 164.530(j)
  deletedAt         DateTime?
  deletedBy         String?
  createdAt         DateTime  @default(now())

  patient    Patient            @relation(fields: [patientId], references: [id])
  assessment PatientAssessment? @relation(fields: [assessmentId], references: [id])

  @@index([patientId])
  @@index([eventType])
  @@index([severity])
  @@index([createdAt])
  @@index([deletedAt])
}

// ============== TREATMENT PLANS ==============

model TreatmentPlan {
  id                     String    @id @default(cuid())
  organizationId         String?
  patientId              String
  encounterId            String
  status                 String    @default("DRAFT") // DRAFT, ACTIVE, COMPLETED, CANCELLED
  diagnosis              String    // JSON array of diagnoses
  chiefComplaint         String?
  clinicalSummary        String?
  labOrders              String?   // JSON array
  imagingOrders          String?   // JSON array
  medicationOrders       String?   // JSON array
  referralOrders         String?   // JSON array
  followUpSchedule       String?   // JSON array
  patientEducation       String?   // JSON array
  returnPrecautions      String?   // JSON array
  additionalInstructions String?
  approvedAt             DateTime?
  approvedBy             String?
  // HIPAA soft-delete
  deletedAt              DateTime?
  deletedBy              String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: Restrict)
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Restrict)

  @@index([patientId])
  @@index([encounterId])
  @@index([status])
  @@index([deletedAt])
  @@index([organizationId])
}

// ============== CLINICAL NOTES ==============

model ClinicalNote {
  id            String    @id @default(cuid())
  organizationId String?
  patientId     String
  encounterId   String
  noteType      String    // PROGRESS, SOAP, H_AND_P, PROCEDURE, DISCHARGE
  status        String    @default("DRAFT") // DRAFT, SIGNED, AMENDED, ADDENDUM
  content       String    // Rich text or structured JSON
  subjective    String?
  objective     String?
  assessment    String?
  plan          String?
  authorId      String
  signedAt      DateTime?
  signedBy      String?
  amendedAt     DateTime?
  amendments    String?   // JSON array of amendments
  // HIPAA soft-delete
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: Restrict)
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Restrict)

  @@index([patientId])
  @@index([encounterId])
  @@index([noteType])
  @@index([status])
  @@index([deletedAt])
  @@index([organizationId])
}

// ============== NOTIFICATIONS ==============

model Notification {
  id          String    @id @default(cuid())
  userId      String
  type        String    // EMERGENCY, RED_FLAG, LAB_RESULT, ORDER_UPDATE, SYSTEM
  priority    String    @default("NORMAL") // CRITICAL, HIGH, NORMAL, LOW
  title       String
  message     String
  data        String?   // JSON additional data
  read        Boolean   @default(false)
  readAt      DateTime?
  actionUrl   String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read, createdAt]) // Unread notification badge count
}

// ============== AUDIT LOG - HIPAA REQUIREMENT ==============

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  action         String   // Action performed (from AuditActions enum)
  userId         String?  // Who performed the action
  entityType     String   // Type of resource accessed
  entityId     String?  // ID of resource accessed
  changes      String?  // JSON: what was changed, includes patientId if PHI
  ipAddress    String?  // Client IP address
  userAgent    String?  // Client user agent
  success      Boolean  @default(true)
  errorMessage String?  // Error message if failed
  createdAt    DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  user User? @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@index([success])
  @@index([organizationId])
  @@index([userId, createdAt])              // User activity reports
  @@index([entityType, entityId, createdAt]) // Resource access history
  @@index([action, createdAt])              // Security event reports
}

// ============== API KEYS (System-to-System Authentication) ==============

model ApiKey {
  id             String    @id @default(cuid())
  name           String
  description    String?
  keyHash        String    @unique // SHA-256 hash of the key (never store plaintext)
  keyPrefix      String    // First 12 chars for human identification
  organizationId String
  scopes         String    // JSON array of scope strings
  rateLimit      Int?      // Custom requests/minute override
  expiresAt      DateTime?
  lastUsedAt     DateTime?
  usageCount     Int       @default(0)
  isActive       Boolean   @default(true)
  createdBy      String    // User ID who created this key
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([keyHash])
  @@index([organizationId])
  @@index([isActive])
}

// ============== WEBHOOKS (Outbound Event Delivery) ==============

model WebhookSubscription {
  id             String    @id @default(cuid())
  name           String
  url            String    // Delivery URL (must be HTTPS in production)
  secret         String    // HMAC-SHA256 signing secret
  organizationId String
  events         String    // JSON array of event types to subscribe to
  isActive       Boolean   @default(true)
  failureCount   Int       @default(0) // Consecutive failures
  disabledAt     DateTime? // Auto-disabled after too many failures
  disabledReason String?
  lastDeliveryAt DateTime?
  lastStatusCode Int?
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  deliveries     WebhookDelivery[]

  @@index([organizationId])
  @@index([isActive])
}

model WebhookDelivery {
  id               String    @id @default(cuid())
  subscriptionId   String
  eventType        String
  payload          String    // JSON event payload
  statusCode       Int?
  responseBody     String?   // Truncated response (max 1KB)
  durationMs       Int?
  attempt          Int       @default(1)
  maxAttempts      Int       @default(5)
  nextRetryAt      DateTime?
  status           String    @default("PENDING") // PENDING, SUCCESS, FAILED, RETRYING
  errorMessage     String?
  createdAt        DateTime  @default(now())

  subscription     WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@index([nextRetryAt])
  @@index([createdAt])
}

// ============== INTEGRATION REGISTRY ==============

model IntegrationConnection {
  id             String    @id @default(cuid())
  name           String
  type           String    // FHIR, HL7V2, WEBHOOK, SFTP, CUSTOM
  direction      String    // INBOUND, OUTBOUND, BIDIRECTIONAL
  organizationId String
  config         String    // Encrypted JSON config (endpoints, credentials ref)
  status         String    @default("ACTIVE") // ACTIVE, PAUSED, ERROR, DISABLED
  lastSyncAt     DateTime?
  lastErrorAt    DateTime?
  lastError      String?
  healthStatus   String    @default("UNKNOWN") // HEALTHY, DEGRADED, DOWN, UNKNOWN
  messageCount   Int       @default(0)
  errorCount     Int       @default(0)
  metadata       String?   // JSON metadata (version, capabilities, etc.)
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([type])
  @@index([status])
}

// ============== FHIR INTEGRATION TABLES ==============

model FhirLabResult {
  id              String   @id @default(cuid())
  patientId       String
  fhirId          String   @unique // FHIR resource ID
  fhirServerId    String   // Which FHIR server this came from
  resourceType    String   @default("Observation")
  rawResource     String   // Full FHIR JSON
  testCode        String?
  testName        String?
  value           String?
  unit            String?
  interpretation  String?
  effectiveDate   DateTime?
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([fhirId])
  @@index([fhirServerId])
}

model FhirCondition {
  id              String   @id @default(cuid())
  patientId       String
  fhirId          String   @unique
  fhirServerId    String
  resourceType    String   @default("Condition")
  rawResource     String
  icdCode         String?
  description     String?
  status          String?
  onsetDate       DateTime?
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([fhirId])
}

model FhirMedication {
  id              String   @id @default(cuid())
  patientId       String
  fhirId          String   @unique
  fhirServerId    String
  resourceType    String   @default("MedicationRequest")
  rawResource     String
  medicationName  String?
  dose            String?
  status          String?
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([fhirId])
}

model FhirVitalSign {
  id              String   @id @default(cuid())
  patientId       String
  fhirId          String   @unique
  fhirServerId    String
  resourceType    String   @default("Observation")
  rawResource     String
  vitalType       String?  // heart-rate, blood-pressure, etc.
  value           String?
  unit            String?
  effectiveDate   DateTime?
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([fhirId])
  @@index([vitalType])
}

// ============== DEAD LETTER QUEUE ==============

model DeadLetterEntry {
  id             String    @id @default(cuid())
  type           String    // webhook, hl7v2, fhir, import, event, custom
  status         String    @default("pending") // pending, replaying, replayed, discarded
  payload        String    // JSON: original message payload
  destination    String    // Target URL or endpoint
  error          String    // Last error message
  attempts       Int       @default(0)
  originalId     String?   // Original message/delivery ID
  organizationId String?
  lastStatusCode Int?      // HTTP status code from last attempt
  metadata       String?   // JSON: additional context
  replayedAt     DateTime?
  replayResult   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([organizationId])
  @@index([createdAt])
  @@index([status, type])  // Dashboard: filter pending by type
}

// ============== CLINICAL PROTOCOLS ==============

model ClinicalProtocol {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String
  version       String
  category      String   // EMERGENCY, CHRONIC_DISEASE, PREVENTIVE, etc.
  triggerRules  String   // JSON: conditions that trigger this protocol
  actions       String   // JSON: recommended actions
  evidenceLevel String?  // A, B, C, D
  guidelineRef  String?  // Reference to clinical guideline
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

// ============== RED FLAG RULES ==============

model RedFlagRule {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String
  category        String   // CARDIOVASCULAR, NEUROLOGICAL, RESPIRATORY, etc.
  severity        String   // CRITICAL, HIGH, MODERATE
  triggerCriteria String   // JSON: symptom patterns and thresholds
  vitalThresholds String?  // JSON: vital sign thresholds
  icdCodes        String?  // JSON: associated ICD-10 codes
  recommendedAction String
  timeframe       String   // IMMEDIATE, URGENT
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([severity])
  @@index([isActive])
}
