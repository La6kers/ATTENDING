// ATTENDING AI - Complete Database Schema
// SQLite for local development (switchable to PostgreSQL for production)
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============== AUTHENTICATION & USERS ==============

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  role          String    @default("PROVIDER")
  specialty     String?
  npi           String?   @unique
  department    String?
  phone         String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  encounters          Encounter[]        @relation("ProviderEncounters")
  labOrders           LabOrder[]
  imagingOrders       ImagingOrder[]
  medicationOrders    MedicationOrder[]
  referrals           Referral[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  assignedAssessments PatientAssessment[] @relation("AssignedProvider")

  @@index([email])
  @@index([npi])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============== PATIENTS ==============

model Patient {
  id              String    @id @default(cuid())
  mrn             String    @unique
  fhirId          String?   @unique
  firstName       String
  lastName        String
  middleName      String?
  dateOfBirth     DateTime
  gender          String?
  email           String?
  phone           String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  emergencyContact String?
  emergencyPhone  String?
  insuranceId     String?
  insuranceName   String?
  primaryProviderId String?
  preferredLanguage String?  @default("en")
  lastFhirSync    DateTime?
  fhirVendor      String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  encounters        Encounter[]
  allergies         Allergy[]
  medications       PatientMedication[]
  conditions        MedicalCondition[]
  assessments       PatientAssessment[]
  vitals            VitalSigns[]
  fhirLabResults    FhirLabResult[]
  fhirConditions    FhirCondition[]
  fhirMedications   FhirMedication[]
  fhirVitalSigns    FhirVitalSign[]

  @@index([mrn])
  @@index([fhirId])
  @@index([lastName, firstName])
  @@index([dateOfBirth])
}

model Allergy {
  id          String   @id @default(cuid())
  patientId   String
  allergen    String
  reaction    String?
  severity    String   @default("MILD")
  type        String   @default("DRUG")
  status      String   @default("ACTIVE")
  onsetDate   DateTime?
  fhirId      String?
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, allergen])
  @@index([patientId])
  @@index([fhirId])
}

model MedicalCondition {
  id          String   @id @default(cuid())
  patientId   String
  name        String
  icdCode     String?
  onsetDate   DateTime?
  status      String   @default("ACTIVE")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model PatientMedication {
  id            String   @id @default(cuid())
  patientId     String
  medicationName String
  genericName   String?
  dose          String?
  frequency     String?
  route         String?
  startDate     DateTime?
  endDate       DateTime?
  prescriber    String?
  pharmacy      String?
  indication    String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model VitalSigns {
  id              String   @id @default(cuid())
  patientId       String
  encounterId     String?
  systolic        Int?
  diastolic       Int?
  heartRate       Int?
  respiratoryRate Int?
  temperature     Float?
  temperatureUnit String?  @default("F")
  oxygenSaturation Int?
  weight          Float?
  weightUnit      String?  @default("lbs")
  height          Float?
  heightUnit      String?  @default("in")
  painLevel       Int?
  bloodGlucose    Int?
  notes           String?
  recordedAt      DateTime @default(now())
  recordedBy      String?

  patient   Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter Encounter? @relation(fields: [encounterId], references: [id])

  @@index([patientId])
  @@index([encounterId])
  @@index([recordedAt])
}

// ============== ENCOUNTERS ==============

model Encounter {
  id              String   @id @default(cuid())
  patientId       String
  providerId      String
  status          String   @default("SCHEDULED")
  visitType       String   @default("OFFICE_VISIT")
  chiefComplaint  String?
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  location        String?
  roomNumber      String?
  reasonForVisit  String?
  clinicalNotes   String?
  assessment      String?
  plan            String?
  followUpDate    DateTime?
  followUpNotes   String?
  billingCode     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient           Patient             @relation(fields: [patientId], references: [id])
  provider          User                @relation("ProviderEncounters", fields: [providerId], references: [id])
  vitals            VitalSigns[]
  labOrders         LabOrder[]
  imagingOrders     ImagingOrder[]
  medicationOrders  MedicationOrder[]
  referrals         Referral[]
  diagnoses         EncounterDiagnosis[]
  patientAssessment PatientAssessment?

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([scheduledAt])
}

model EncounterDiagnosis {
  id          String   @id @default(cuid())
  encounterId String
  name        String
  icdCode     String?
  probability Float?
  isPrimary   Boolean  @default(false)
  isConfirmed Boolean  @default(false)
  evidence    String   @default("[]")
  notes       String?
  createdAt   DateTime @default(now())

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId])
}

// ============== COMPASS ASSESSMENTS ==============

model PatientAssessment {
  id                String    @id @default(cuid())
  patientId         String
  encounterId       String?   @unique
  sessionId         String    @unique
  assignedProviderId String?
  
  chiefComplaint    String
  hpiOnset          String?
  hpiLocation       String?
  hpiDuration       String?
  hpiCharacter      String?
  hpiSeverity       Int?
  hpiAggravating    String   @default("[]")
  hpiRelieving      String   @default("[]")
  hpiAssociated     String   @default("[]")
  hpiTiming         String?
  
  reviewOfSystems   String?
  medications       String   @default("[]")
  allergies         String   @default("[]")
  medicalHistory    String   @default("[]")
  surgicalHistory   String   @default("[]")
  familyHistory     String?
  socialHistory     String?
  
  urgencyLevel      String   @default("STANDARD")
  urgencyScore      Int      @default(0)
  redFlags          String   @default("[]")
  riskFactors       String   @default("[]")
  
  differentialDx    String?
  aiRecommendations String   @default("[]")
  clinicalPearls    String   @default("[]")
  
  status            String   @default("IN_PROGRESS")
  submittedAt       DateTime?
  reviewedAt        DateTime?
  completedAt       DateTime?
  
  providerNotes     String?
  confirmedDiagnoses String?
  icdCodes          String   @default("[]")
  treatmentPlan     String?
  followUpInstructions String?
  ordersPlaced      String   @default("[]")
  
  compassVersion    String?
  aiModelUsed       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  patient           Patient   @relation(fields: [patientId], references: [id])
  encounter         Encounter? @relation(fields: [encounterId], references: [id])
  assignedProvider  User?     @relation("AssignedProvider", fields: [assignedProviderId], references: [id])

  @@index([patientId])
  @@index([status])
  @@index([urgencyLevel])
  @@index([submittedAt])
}

// ============== ORDERS ==============

model LabOrder {
  id            String   @id @default(cuid())
  encounterId   String
  orderedById   String
  testCode      String
  testName      String
  category      String?
  priority      String   @default("ROUTINE")
  status        String   @default("PENDING")
  indication    String?
  specialInstructions String?
  specimenType  String?
  collectionDate DateTime?
  orderedAt     DateTime @default(now())
  collectedAt   DateTime?
  resultedAt    DateTime?
  notes         String?

  encounter   Encounter   @relation(fields: [encounterId], references: [id])
  orderedBy   User        @relation(fields: [orderedById], references: [id])
  results     LabResult[]

  @@index([encounterId])
  @@index([orderedById])
  @@index([status])
  @@index([priority])
}

model LabResult {
  id             String   @id @default(cuid())
  labOrderId     String
  analyte        String
  value          String
  unit           String?
  referenceRange String?
  isAbnormal     Boolean  @default(false)
  isCritical     Boolean  @default(false)
  interpretation String?
  resultedAt     DateTime @default(now())
  verifiedBy     String?
  notes          String?

  labOrder LabOrder @relation(fields: [labOrderId], references: [id], onDelete: Cascade)

  @@index([labOrderId])
}

model ImagingOrder {
  id            String   @id @default(cuid())
  encounterId   String
  orderedById   String
  studyType     String
  studyName     String
  bodyPart      String?
  laterality    String?
  priority      String   @default("ROUTINE")
  status        String   @default("PENDING")
  indication    String
  clinicalHistory String?
  contrast      Boolean  @default(false)
  contrastType  String?
  radiationDose String?
  specialInstructions String?
  orderedAt     DateTime @default(now())
  scheduledAt   DateTime?
  performedAt   DateTime?
  readAt        DateTime?
  report        String?
  impression    String?
  findings      String?
  radiologist   String?
  facility      String?
  notes         String?

  encounter Encounter @relation(fields: [encounterId], references: [id])
  orderedBy User      @relation(fields: [orderedById], references: [id])

  @@index([encounterId])
  @@index([orderedById])
  @@index([status])
}

model MedicationOrder {
  id              String   @id @default(cuid())
  encounterId     String
  orderedById     String
  medicationName  String
  genericName     String?
  dose            String
  doseUnit        String?
  frequency       String
  route           String
  duration        String?
  quantity        Int?
  refills         Int?      @default(0)
  indication      String?
  instructions    String?
  status          String   @default("PENDING")
  priority        String   @default("ROUTINE")
  isControlled    Boolean   @default(false)
  deaSchedule     String?
  pharmacy        String?
  dispenseAsWritten Boolean @default(false)
  priorAuthRequired Boolean @default(false)
  priorAuthStatus String?
  orderedAt       DateTime  @default(now())
  startDate       DateTime?
  endDate         DateTime?
  discontinuedAt  DateTime?
  discontinuedBy  String?
  discontinueReason String?
  notes           String?

  encounter      Encounter         @relation(fields: [encounterId], references: [id])
  orderedBy      User              @relation(fields: [orderedById], references: [id])
  interactions   DrugInteraction[] @relation("InteractingMedication")

  @@index([encounterId])
  @@index([orderedById])
  @@index([status])
}

model DrugInteraction {
  id              String   @id @default(cuid())
  medicationOrderId String
  interactingDrug String
  severity        String
  description     String
  mechanism       String?
  management      String?
  acknowledged    Boolean  @default(false)
  acknowledgedBy  String?
  acknowledgedAt  DateTime?
  createdAt       DateTime @default(now())

  medicationOrder MedicationOrder @relation("InteractingMedication", fields: [medicationOrderId], references: [id], onDelete: Cascade)

  @@index([medicationOrderId])
}

// ============== REFERRALS ==============

model Referral {
  id              String   @id @default(cuid())
  encounterId     String
  referringProviderId String
  specialty       String
  urgency         String   @default("ROUTINE")
  status          String   @default("PENDING")
  reason          String
  clinicalSummary String?
  specificQuestions String?
  preferredProvider String?
  preferredFacility String?
  insurancePreAuth Boolean @default(false)
  preAuthStatus   String?
  preAuthNumber   String?
  appointmentDate DateTime?
  appointmentTime String?
  consultNote     String?
  recommendations String?
  followUpNeeded  Boolean  @default(false)
  orderedAt       DateTime @default(now())
  sentAt          DateTime?
  scheduledAt     DateTime?
  completedAt     DateTime?
  notes           String?

  encounter        Encounter @relation(fields: [encounterId], references: [id])
  referringProvider User     @relation(fields: [referringProviderId], references: [id])

  @@index([encounterId])
  @@index([referringProviderId])
  @@index([status])
  @@index([specialty])
}

// ============== NOTIFICATIONS ==============

model Notification {
  id            String   @id @default(cuid())
  userId        String
  type          String
  title         String
  message       String
  priority      String   @default("NORMAL")
  isRead        Boolean  @default(false)
  readAt        DateTime?
  relatedType   String?
  relatedId     String?
  actionUrl     String?
  expiresAt     DateTime?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
}

// ============== EMERGENCY EVENTS ==============

model EmergencyEvent {
  id              String   @id @default(cuid())
  assessmentId    String?
  patientId       String?
  eventType       String
  triggeredBy     String
  severity        String
  protocol        String
  autoOrders      String   @default("[]")
  location        String?
  acknowledgedAt  DateTime?
  acknowledgedBy  String?
  resolvedAt      DateTime?
  resolvedBy      String?
  resolution      String?
  notes           String?
  createdAt       DateTime @default(now())

  @@index([assessmentId])
  @@index([patientId])
  @@index([createdAt])
}

// ============== AUDIT LOGGING ==============

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String
  entityId    String?
  changes     String?
  ipAddress   String?
  userAgent   String?
  sessionId   String?
  success     Boolean  @default(true)
  errorMessage String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

// ============== CLINICAL DECISION SUPPORT ==============

model ClinicalProtocol {
  id            String   @id @default(cuid())
  name          String
  condition     String
  triggerCriteria String
  recommendedActions String
  labOrders     String?
  imagingOrders String?
  medications   String?
  referrals     String?
  patientEducation String?
  followUp      String?
  evidenceLevel String?
  references    String   @default("[]")
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([condition])
  @@index([isActive])
}

model PatientEducationMaterial {
  id          String   @id @default(cuid())
  title       String
  category    String
  content     String
  format      String   @default("text")
  url         String?
  language    String   @default("en")
  readingLevel String?
  conditions  String   @default("[]")
  keywords    String   @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

// ============== TREATMENT PLANS ==============

model TreatmentPlan {
  id                    String   @id @default(cuid())
  encounterId           String   @unique
  patientId             String
  providerId            String
  diagnoses             String   @default("[]")
  chiefComplaint        String?
  clinicalSummary       String?
  labOrderIds           String   @default("[]")
  imagingOrderIds       String   @default("[]")
  prescriptionIds       String   @default("[]")
  referralIds           String   @default("[]")
  followUpSchedule      String   @default("[]")
  patientEducation      String   @default("[]")
  returnPrecautions     String   @default("[]")
  additionalInstructions String?
  protocolApplied       String?
  status                String   @default("DRAFT")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  approvedBy            String?
  approvedAt            DateTime?

  @@index([patientId])
  @@index([providerId])
  @@index([status])
}

// ============== PROVIDER DIRECTORY ==============

model ProviderDirectory {
  id                   String   @id @default(cuid())
  name                 String
  credentials          String
  specialty            String
  subspecialty         String?
  organization         String
  address              String
  phone                String
  fax                  String?
  npi                  String?  @unique
  acceptingNew         Boolean  @default(true)
  insurancesAccepted   String   @default("[]")
  nextAvailableRoutine String?
  nextAvailableUrgent  String?
  rating               Float?
  preferred            Boolean  @default(false)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([specialty])
  @@index([subspecialty])
  @@index([acceptingNew])
  @@index([preferred])
}

// ============== FHIR INTEGRATION ==============

model FhirConnection {
  id           String   @id @default(cuid())
  providerId   String
  vendor       String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  patientId    String?
  encounterId  String?
  scope        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([providerId, vendor])
  @@index([providerId])
}

model OAuthState {
  id        String   @id @default(cuid())
  state     String   @unique
  context   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([state])
  @@index([expiresAt])
}

model FhirLabResult {
  id             String   @id @default(cuid())
  patientId      String
  testName       String
  testCode       String?
  value          String
  unit           String?
  referenceRange String?
  interpretation String?
  status         String   @default("FINAL")
  collectedAt    DateTime
  resultedAt     DateTime
  performedBy    String?
  notes          String?
  fhirId         String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([testCode])
  @@index([fhirId])
}

model FhirCondition {
  id           String    @id @default(cuid())
  patientId    String
  name         String
  icdCode      String?
  status       String    @default("ACTIVE")
  onsetDate    DateTime?
  recordedDate DateTime
  notes        String?
  fhirId       String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([icdCode])
  @@index([fhirId])
}

model FhirMedication {
  id             String    @id @default(cuid())
  patientId      String
  medicationName String
  genericName    String?
  dosage         String?
  frequency      String?
  route          String?
  status         String    @default("ACTIVE")
  prescribedDate DateTime
  prescriber     String?
  startDate      DateTime?
  endDate        DateTime?
  notes          String?
  fhirId         String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([fhirId])
}

model FhirVitalSign {
  id         String   @id @default(cuid())
  patientId  String
  type       String
  value      String
  unit       String?
  systolic   Int?
  diastolic  Int?
  recordedAt DateTime
  recordedBy String?
  fhirId     String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([type])
  @@index([fhirId])
}

model FhirEncounter {
  id             String    @id @default(cuid())
  patientId      String
  status         String
  type           String?
  class          String?
  startTime      DateTime
  endTime        DateTime?
  reasonForVisit String?
  fhirId         String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([patientId])
  @@index([fhirId])
}
