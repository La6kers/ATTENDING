// ATTENDING AI - Complete Database Schema
// Production: PostgreSQL with encryption at rest
// Development: SQLite for local testing
// 
// HIPAA Requirement: 164.312(a)(2)(iv) - Encryption and Decryption
// Production database MUST have encryption at rest enabled
//
// Run: npx prisma migrate dev --name init
// Production: npx prisma migrate deploy

generator client {
  provider = "prisma-client-js"
}

// Use environment variable to switch between SQLite (dev) and PostgreSQL (prod)
// Development: DATABASE_URL="file:./dev.db"
// Production: DATABASE_URL="postgresql://user:pass@host:5432/attending?sslmode=require"
datasource db {
  provider = env("DATABASE_PROVIDER") // "sqlite" or "postgresql"
  url      = env("DATABASE_URL")
}

// ============== AUTHENTICATION & USERS ==============

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?   // Hashed with bcrypt, never stored plain
  role          String    @default("PROVIDER") // ADMIN, PROVIDER, NURSE, STAFF, PATIENT
  specialty     String?
  npi           String?   @unique // National Provider Identifier
  deaNumber     String?   // DEA number for controlled substances
  department    String?
  phone         String?
  isActive      Boolean   @default(true)
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?   // Encrypted TOTP secret
  lastLoginAt   DateTime?
  failedLoginAttempts Int @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  encounters          Encounter[]        @relation("ProviderEncounters")
  labOrders           LabOrder[]
  imagingOrders       ImagingOrder[]
  medicationOrders    MedicationOrder[]
  referrals           Referral[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  assignedAssessments PatientAssessment[] @relation("AssignedProvider")

  @@index([email])
  @@index([npi])
  @@index([role])
  @@index([isActive])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============== PATIENTS ==============

model Patient {
  id                 String    @id @default(cuid())
  mrn                String    @unique // Medical Record Number
  firstName          String
  lastName           String
  middleName         String?
  dateOfBirth        DateTime
  gender             String?
  sex                String?
  email              String?
  phone              String?
  address            String?
  city               String?
  state              String?
  zipCode            String?
  emergencyContact   String?
  emergencyPhone     String?
  insuranceProvider  String?
  insurancePolicyNum String?
  preferredLanguage  String    @default("en")
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  encounters        Encounter[]
  allergies         Allergy[]
  conditions        Condition[]
  medications       Medication[]
  vitalSigns        VitalSign[]
  labOrders         LabOrder[]
  labResults        LabResult[]
  imagingOrders     ImagingOrder[]
  imagingResults    ImagingResult[]
  medicationOrders  MedicationOrder[]
  referrals         Referral[]
  assessments       PatientAssessment[]
  emergencyEvents   EmergencyEvent[]
  treatmentPlans    TreatmentPlan[]
  fhirLabResults    FhirLabResult[]
  fhirConditions    FhirCondition[]
  fhirMedications   FhirMedication[]
  fhirVitalSigns    FhirVitalSign[]
  clinicalNotes     ClinicalNote[]

  @@index([mrn])
  @@index([lastName, firstName])
  @@index([dateOfBirth])
  @@index([isActive])
}

// ============== CLINICAL ENCOUNTERS ==============

model Encounter {
  id              String    @id @default(cuid())
  patientId       String
  providerId      String
  facilityId      String?
  encounterType   String    // OFFICE, TELEHEALTH, EMERGENCY, INPATIENT
  status          String    @default("IN_PROGRESS") // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED
  chiefComplaint  String?
  startTime       DateTime  @default(now())
  endTime         DateTime?
  notes           String?
  diagnosis       String?   // JSON array of diagnosis codes
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  patient          Patient            @relation(fields: [patientId], references: [id])
  provider         User               @relation("ProviderEncounters", fields: [providerId], references: [id])
  labOrders        LabOrder[]
  imagingOrders    ImagingOrder[]
  medicationOrders MedicationOrder[]
  referrals        Referral[]
  vitalSigns       VitalSign[]
  treatmentPlans   TreatmentPlan[]
  clinicalNotes    ClinicalNote[]

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([startTime])
}

// ============== ALLERGIES ==============

model Allergy {
  id         String    @id @default(cuid())
  patientId  String
  allergen   String
  reaction   String?
  severity   String?   // MILD, MODERATE, SEVERE, LIFE_THREATENING
  onsetDate  DateTime?
  status     String    @default("ACTIVE") // ACTIVE, INACTIVE, RESOLVED
  verifiedAt DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([allergen])
}

// ============== CONDITIONS / DIAGNOSES ==============

model Condition {
  id            String    @id @default(cuid())
  patientId     String
  icdCode       String
  description   String
  status        String    @default("ACTIVE") // ACTIVE, RESOLVED, INACTIVE
  onsetDate     DateTime?
  abatementDate DateTime?
  isPrimary     Boolean   @default(false)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([icdCode])
  @@index([status])
}

// ============== MEDICATIONS ==============

model Medication {
  id            String    @id @default(cuid())
  patientId     String
  name          String
  genericName   String?
  rxnormCode    String?
  ndcCode       String?
  dose          String?
  frequency     String?
  route         String?
  status        String    @default("ACTIVE") // ACTIVE, COMPLETED, DISCONTINUED, ON_HOLD
  startDate     DateTime?
  endDate       DateTime?
  prescribedBy  String?
  pharmacy      String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([name])
  @@index([status])
}

// ============== VITAL SIGNS ==============

model VitalSign {
  id                    String   @id @default(cuid())
  patientId             String
  encounterId           String?
  heartRate             Int?
  bloodPressureSystolic Int?
  bloodPressureDiastolic Int?
  respiratoryRate       Int?
  temperature           Float?
  temperatureUnit       String   @default("F")
  oxygenSaturation      Float?
  weight                Float?
  weightUnit            String   @default("lbs")
  height                Float?
  heightUnit            String   @default("in")
  painLevel             Int?
  bloodGlucose          Float?
  notes                 String?
  recordedAt            DateTime @default(now())
  recordedBy            String?
  createdAt             DateTime @default(now())

  patient   Patient    @relation(fields: [patientId], references: [id])
  encounter Encounter? @relation(fields: [encounterId], references: [id])

  @@index([patientId])
  @@index([encounterId])
  @@index([recordedAt])
}

// ============== LAB ORDERS ==============

model LabOrder {
  id                  String    @id @default(cuid())
  patientId           String
  providerId          String
  encounterId         String?
  orderNumber         String    @unique
  status              String    @default("PENDING") // PENDING, COLLECTED, IN_PROGRESS, COMPLETED, CANCELLED
  priority            String    @default("ROUTINE") // STAT, ASAP, ROUTINE, TIMED
  tests               String    // JSON array of ordered tests
  diagnosis           String?   // JSON array of diagnosis codes
  indication          String?
  specialInstructions String?
  specimenType        String?
  collectionDate      DateTime?
  fasting             Boolean   @default(false)
  orderedAt           DateTime  @default(now())
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  patient   Patient     @relation(fields: [patientId], references: [id])
  provider  User        @relation(fields: [providerId], references: [id])
  encounter Encounter?  @relation(fields: [encounterId], references: [id])
  results   LabResult[]

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([orderedAt])
}

model LabResult {
  id           String    @id @default(cuid())
  patientId    String
  labOrderId   String?
  testCode     String
  testName     String
  loincCode    String?
  value        String
  unit         String?
  referenceRange String?
  interpretation String? // NORMAL, HIGH, LOW, CRITICAL_HIGH, CRITICAL_LOW
  status       String    @default("FINAL") // PRELIMINARY, FINAL, CORRECTED
  performedAt  DateTime?
  reportedAt   DateTime  @default(now())
  notes        String?
  createdAt    DateTime  @default(now())

  patient  Patient   @relation(fields: [patientId], references: [id])
  labOrder LabOrder? @relation(fields: [labOrderId], references: [id])

  @@index([patientId])
  @@index([labOrderId])
  @@index([testCode])
  @@index([interpretation])
}

// ============== IMAGING ORDERS ==============

model ImagingOrder {
  id                  String    @id @default(cuid())
  patientId           String
  providerId          String
  encounterId         String?
  orderNumber         String    @unique
  status              String    @default("PENDING") // PENDING, SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED
  priority            String    @default("ROUTINE") // STAT, URGENT, ROUTINE
  studyType           String    // X-RAY, CT, MRI, ULTRASOUND, etc.
  studyName           String
  bodyPart            String
  laterality          String?   // LEFT, RIGHT, BILATERAL
  indication          String
  clinicalHistory     String?
  contrast            Boolean   @default(false)
  contrastType        String?
  specialInstructions String?
  diagnosis           String?   // JSON array
  scheduledDate       DateTime?
  orderedAt           DateTime  @default(now())
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  patient   Patient         @relation(fields: [patientId], references: [id])
  provider  User            @relation(fields: [providerId], references: [id])
  encounter Encounter?      @relation(fields: [encounterId], references: [id])
  results   ImagingResult[]

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([orderedAt])
}

model ImagingResult {
  id             String    @id @default(cuid())
  patientId      String
  imagingOrderId String?
  studyType      String
  studyName      String
  findings       String
  impression     String?
  radiologistId  String?
  status         String    @default("FINAL") // PRELIMINARY, FINAL, ADDENDUM
  performedAt    DateTime?
  reportedAt     DateTime  @default(now())
  createdAt      DateTime  @default(now())

  patient      Patient       @relation(fields: [patientId], references: [id])
  imagingOrder ImagingOrder? @relation(fields: [imagingOrderId], references: [id])

  @@index([patientId])
  @@index([imagingOrderId])
}

// ============== MEDICATION ORDERS ==============

model MedicationOrder {
  id                   String    @id @default(cuid())
  patientId            String
  providerId           String
  encounterId          String?
  orderNumber          String    @unique
  status               String    @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED, ON_HOLD
  medicationName       String
  genericName          String?
  rxnormCode           String?
  ndcCode              String?
  dose                 String
  doseUnit             String?
  frequency            String
  route                String
  duration             String?
  quantity             Int?
  refills              Int       @default(0)
  indication           String
  instructions         String?
  isControlled         Boolean   @default(false)
  deaSchedule          String?   // II, III, IV, V
  dispenseAsWritten    Boolean   @default(false)
  substitutionAllowed  Boolean   @default(true)
  priorAuthRequired    Boolean   @default(false)
  priorAuthStatus      String?   // PENDING, APPROVED, DENIED
  diagnosis            String?   // JSON array
  pharmacy             String?
  pharmacyNpi          String?
  orderedAt            DateTime  @default(now())
  discontinuedAt       DateTime?
  discontinuedReason   String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  patient   Patient    @relation(fields: [patientId], references: [id])
  provider  User       @relation(fields: [providerId], references: [id])
  encounter Encounter? @relation(fields: [encounterId], references: [id])

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([isControlled])
  @@index([orderedAt])
}

// ============== REFERRALS ==============

model Referral {
  id                String    @id @default(cuid())
  patientId         String
  providerId        String
  encounterId       String?
  orderNumber       String    @unique
  status            String    @default("PENDING") // PENDING, SENT, SCHEDULED, COMPLETED, CANCELLED
  urgency           String    @default("ROUTINE") // STAT, URGENT, ROUTINE, ELECTIVE
  specialty         String
  subspecialty      String?
  reason            String
  clinicalSummary   String?
  specificQuestions String?
  preferredProvider String?
  preferredFacility String?
  diagnosis         String?   // JSON array
  insurancePreAuth  Boolean   @default(false)
  preAuthStatus     String?
  scheduledDate     DateTime?
  orderedAt         DateTime  @default(now())
  completedAt       DateTime?
  consultNote       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  patient   Patient    @relation(fields: [patientId], references: [id])
  provider  User       @relation(fields: [providerId], references: [id])
  encounter Encounter? @relation(fields: [encounterId], references: [id])

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([specialty])
}

// ============== PATIENT ASSESSMENTS (COMPASS) ==============

model PatientAssessment {
  id                 String    @id @default(cuid())
  patientId          String
  assignedProviderId String?
  sessionId          String    @unique
  status             String    @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, ABANDONED, EMERGENCY
  phase              String    @default("GREETING")
  chiefComplaint     String?
  symptoms           String?   // JSON array
  hpiNarrative       String?
  reviewOfSystems    String?   // JSON object
  medicalHistory     String?   // JSON array
  medications        String?   // JSON array
  allergies          String?   // JSON array
  vitalSigns         String?   // JSON object
  triageLevel        String?   // ESI 1-5 or custom
  redFlagsDetected   String?   // JSON array of detected red flags
  aiSummary          String?
  aiDifferential     String?   // JSON array of differential diagnoses
  conversation       String?   // JSON array of chat messages
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  lastActivityAt     DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  patient          Patient          @relation(fields: [patientId], references: [id])
  assignedProvider User?            @relation("AssignedProvider", fields: [assignedProviderId], references: [id])
  emergencyEvents  EmergencyEvent[]

  @@index([patientId])
  @@index([assignedProviderId])
  @@index([status])
  @@index([sessionId])
}

// ============== EMERGENCY EVENTS ==============

model EmergencyEvent {
  id                String   @id @default(cuid())
  patientId         String
  assessmentId      String?
  eventType         String   // RED_FLAG, CRASH_DETECTION, MANUAL_TRIGGER
  severity          String   // CRITICAL, HIGH, MODERATE
  description       String
  triggeredBy       String   // SYSTEM, PATIENT, PROVIDER
  symptoms          String?  // JSON array
  vitalSigns        String?  // JSON object
  location          String?  // GPS coordinates or address
  acknowledgedAt    DateTime?
  acknowledgedBy    String?
  resolvedAt        DateTime?
  resolvedBy        String?
  resolution        String?
  notificationsSent String?  // JSON array of notifications sent
  createdAt         DateTime @default(now())

  patient    Patient            @relation(fields: [patientId], references: [id])
  assessment PatientAssessment? @relation(fields: [assessmentId], references: [id])

  @@index([patientId])
  @@index([eventType])
  @@index([severity])
  @@index([createdAt])
}

// ============== TREATMENT PLANS ==============

model TreatmentPlan {
  id                     String    @id @default(cuid())
  patientId              String
  encounterId            String
  status                 String    @default("DRAFT") // DRAFT, ACTIVE, COMPLETED, CANCELLED
  diagnosis              String    // JSON array of diagnoses
  chiefComplaint         String?
  clinicalSummary        String?
  labOrders              String?   // JSON array
  imagingOrders          String?   // JSON array
  medicationOrders       String?   // JSON array
  referralOrders         String?   // JSON array
  followUpSchedule       String?   // JSON array
  patientEducation       String?   // JSON array
  returnPrecautions      String?   // JSON array
  additionalInstructions String?
  approvedAt             DateTime?
  approvedBy             String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  patient   Patient   @relation(fields: [patientId], references: [id])
  encounter Encounter @relation(fields: [encounterId], references: [id])

  @@index([patientId])
  @@index([encounterId])
  @@index([status])
}

// ============== CLINICAL NOTES ==============

model ClinicalNote {
  id            String    @id @default(cuid())
  patientId     String
  encounterId   String
  noteType      String    // PROGRESS, SOAP, H_AND_P, PROCEDURE, DISCHARGE
  status        String    @default("DRAFT") // DRAFT, SIGNED, AMENDED, ADDENDUM
  content       String    // Rich text or structured JSON
  subjective    String?
  objective     String?
  assessment    String?
  plan          String?
  authorId      String
  signedAt      DateTime?
  signedBy      String?
  amendedAt     DateTime?
  amendments    String?   // JSON array of amendments
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient   Patient   @relation(fields: [patientId], references: [id])
  encounter Encounter @relation(fields: [encounterId], references: [id])

  @@index([patientId])
  @@index([encounterId])
  @@index([noteType])
  @@index([status])
}

// ============== NOTIFICATIONS ==============

model Notification {
  id          String    @id @default(cuid())
  userId      String
  type        String    // EMERGENCY, RED_FLAG, LAB_RESULT, ORDER_UPDATE, SYSTEM
  priority    String    @default("NORMAL") // CRITICAL, HIGH, NORMAL, LOW
  title       String
  message     String
  data        String?   // JSON additional data
  read        Boolean   @default(false)
  readAt      DateTime?
  actionUrl   String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([read])
  @@index([createdAt])
}

// ============== AUDIT LOG - HIPAA REQUIREMENT ==============

model AuditLog {
  id           String   @id @default(cuid())
  action       String   // Action performed (from AuditActions enum)
  userId       String?  // Who performed the action
  entityType   String   // Type of resource accessed
  entityId     String?  // ID of resource accessed
  changes      String?  // JSON: what was changed, includes patientId if PHI
  ipAddress    String?  // Client IP address
  userAgent    String?  // Client user agent
  success      Boolean  @default(true)
  errorMessage String?  // Error message if failed
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@index([success])
}

// ============== FHIR INTEGRATION TABLES ==============

model FhirLabResult {
  id              String   @id @default(cuid())
  patientId       String
  fhirId          String   @unique // FHIR resource ID
  fhirServerId    String   // Which FHIR server this came from
  resourceType    String   @default("Observation")
  rawResource     String   // Full FHIR JSON
  testCode        String?
  testName        String?
  value           String?
  unit            String?
  interpretation  String?
  effectiveDate   DateTime?
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([fhirId])
  @@index([fhirServerId])
}

model FhirCondition {
  id              String   @id @default(cuid())
  patientId       String
  fhirId          String   @unique
  fhirServerId    String
  resourceType    String   @default("Condition")
  rawResource     String
  icdCode         String?
  description     String?
  status          String?
  onsetDate       DateTime?
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([fhirId])
}

model FhirMedication {
  id              String   @id @default(cuid())
  patientId       String
  fhirId          String   @unique
  fhirServerId    String
  resourceType    String   @default("MedicationRequest")
  rawResource     String
  medicationName  String?
  dose            String?
  status          String?
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([fhirId])
}

model FhirVitalSign {
  id              String   @id @default(cuid())
  patientId       String
  fhirId          String   @unique
  fhirServerId    String
  resourceType    String   @default("Observation")
  rawResource     String
  vitalType       String?  // heart-rate, blood-pressure, etc.
  value           String?
  unit            String?
  effectiveDate   DateTime?
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([fhirId])
  @@index([vitalType])
}

// ============== CLINICAL PROTOCOLS ==============

model ClinicalProtocol {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String
  version       String
  category      String   // EMERGENCY, CHRONIC_DISEASE, PREVENTIVE, etc.
  triggerRules  String   // JSON: conditions that trigger this protocol
  actions       String   // JSON: recommended actions
  evidenceLevel String?  // A, B, C, D
  guidelineRef  String?  // Reference to clinical guideline
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

// ============== RED FLAG RULES ==============

model RedFlagRule {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String
  category        String   // CARDIOVASCULAR, NEUROLOGICAL, RESPIRATORY, etc.
  severity        String   // CRITICAL, HIGH, MODERATE
  triggerCriteria String   // JSON: symptom patterns and thresholds
  vitalThresholds String?  // JSON: vital sign thresholds
  icdCodes        String?  // JSON: associated ICD-10 codes
  recommendedAction String
  timeframe       String   // IMMEDIATE, URGENT
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([severity])
  @@index([isActive])
}
