// ============== WEBHOOK INTEGRATION ==============
// COMPASS standalone webhook system — enables practices to push
// assessment data to their EHR, Slack, or any HTTP endpoint.
// Supports COMPASS JSON, FHIR R4 Bundle, and HL7v2 ORU formats.

model WebhookConfig {
  id       String  @id @default(cuid())
  name     String // "Epic Integration", "Slack Alerts"
  url      String // https://ehr.practice.com/api/intake
  secret   String // HMAC-SHA256 signing secret (encrypted at rest)
  format   String  @default("json") // json | fhir_r4 | hl7v2
  events   String  @db.NVarChar(Max) // JSON array: ["assessment.completed", "assessment.emergency"]
  isActive Boolean @default(true)
  headers  String? @db.NVarChar(Max) // Custom headers as JSON (e.g., auth bearer tokens)

  // Health tracking — auto-disable after consecutive failures
  consecutiveFailures Int       @default(0)
  lastSuccessAt       DateTime?
  lastFailureAt       DateTime?
  disabledAt          DateTime? // Set when auto-disabled
  disabledReason      String?

  // Audit
  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?

  // Multi-tenant (optional — null for standalone COMPASS)
  organizationId String?

  deliveries WebhookDelivery[]

  @@index([isActive])
  @@index([organizationId])
  @@map("webhook_configs")
}

model WebhookDelivery {
  id        String        @id @default(cuid())
  webhookId String
  webhook   WebhookConfig @relation(fields: [webhookId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // What triggered this delivery
  event        String // assessment.completed, assessment.emergency, etc.
  assessmentId String?
  patientId    String?

  // Delivery details
  deliveryId    String  @unique // Idempotency key sent as X-Compass-Delivery-Id
  attemptNumber Int     @default(1) // 1 = initial, 2-6 = retries
  status        String // pending | success | failed | retrying
  httpStatus    Int? // 200, 404, 500, etc.
  responseBody  String? @db.NVarChar(1000) // Truncated response for debugging
  latencyMs     Int? // Round-trip time in milliseconds
  errorMessage  String? // Connection refused, timeout, etc.

  // Retry scheduling
  scheduledAt DateTime // When this attempt was scheduled
  attemptedAt DateTime? // When delivery was actually attempted
  nextRetryAt DateTime? // When to retry (null if success or final failure)

  createdAt DateTime @default(now())

  @@index([webhookId, createdAt])
  @@index([status, scheduledAt]) // For retry queue queries
  @@index([assessmentId])
  @@index([deliveryId])
  @@map("webhook_deliveries")
}

// ============== POPULATION-AWARE CHART DISPLAY ==============
// These models drive context-sensitive chart rendering based on
// patient demographics (age, gender identity, pregnancy, conditions).
// See: docs/CLINICAL_CHART_DESIGN.md for display logic.

// Auto-detected or manually assigned population flags per patient.
// Drives which chart sections, screening protocols, vital ranges,
// and medication warnings are surfaced to the provider.
model PatientPopulationFlag {
  id             String    @id @default(cuid())
  patientId      String
  organizationId String
  flag           String // PEDIATRIC, NEONATAL, ADOLESCENT, GERIATRIC, TRANSGENDER,
  // PREGNANT, POSTPARTUM, CHRONIC_KIDNEY_DISEASE, DIABETES,
  // HEART_FAILURE, SUBSTANCE_USE_DISORDER, HOSPICE,
  // COGNITIVE_IMPAIRMENT, FALL_RISK
  autoDetected  Boolean   @default(true) // true = system-derived from age/conditions; false = manually set
  metadata      String?   @db.NVarChar(Max) // JSON: extra context (e.g., { "edc": "2026-09-15" } for pregnancy)
  activatedAt   DateTime  @default(now())
  deactivatedAt DateTime? // Null = currently active
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([patientId, flag]) // One flag per type per patient
  @@index([patientId])
  @@index([flag])
  @@index([deactivatedAt])
  @@index([organizationId])
}

// Age-stratified normal ranges for vital signs.
// Used to interpret whether a vital value is normal/elevated/critical
// based on patient age rather than a single adult range.
model VitalSignReference {
  id           String   @id @default(cuid())
  vitalType    String // HR, SBP, DBP, RR, TEMP, SPO2, WEIGHT_PERCENTILE, HEIGHT_PERCENTILE
  ageMinMonths Int // Inclusive lower bound (0 = birth)
  ageMaxMonths Int // Inclusive upper bound (1440 = 120 years)
  normalMin    Float
  normalMax    Float
  criticalMin  Float? // Below this = critical
  criticalMax  Float? // Above this = critical
  unit         String // bpm, mmHg, breaths/min, °F, %, etc.
  source       String? // Evidence source: "AHA 2023", "WHO Growth Standards", "AAP"
  notes        String? // Clinical context
  createdAt    DateTime @default(now())

  @@unique([vitalType, ageMinMonths, ageMaxMonths]) // One range per vital per age bracket
  @@index([vitalType])
  @@index([ageMinMonths, ageMaxMonths])
}

// Rules that control which chart sections are shown, hidden, promoted,
// or modified based on population flags. Evaluated at render time.
model ChartDisplayRule {
  id             String   @id @default(cuid())
  populationFlag String // Which population flag triggers this rule
  section        String // VITALS, MEDICATIONS, HISTORY, SCREENING, SOCIAL,
  // GOALS_OF_CARE, GROWTH_CHART, BIRTH_HISTORY,
  // FUNCTIONAL_STATUS, IMMUNIZATIONS, DEVELOPMENTAL
  action         String // SHOW, HIDE, PROMOTE, DEMOTE, REPLACE, WARN, BADGE
  priority       Int      @default(0) // Higher = more prominent placement in the chart
  config         String?  @db.NVarChar(Max) // JSON config for the action. Examples:
  // PROMOTE: { "position": "top" }
  // WARN: { "enableBeers": true, "polypharmacyThreshold": 5 }
  // REPLACE: { "replaceWith": "BIRTH_HISTORY" }
  // BADGE: { "label": "Fall Risk", "color": "red" }
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([populationFlag, section, action]) // One rule per flag+section+action combo
  @@index([populationFlag])
  @@index([isActive])
}

// Age- and organ-specific screening protocols.
// Drives the "Screenings Due" section of the patient chart.
// Uses organ inventory (not assumed gender) for transgender patients.
model ScreeningProtocol {
  id              String   @id @default(cuid())
  name            String // "Cervical Cancer Screening", "Mammogram", "Colonoscopy", etc.
  screeningCode   String? // CPT or LOINC code
  description     String?
  populationFlags String?  @db.NVarChar(Max) // JSON array of flags that trigger this: ["GERIATRIC", "DIABETES"]
  organRequired   String? // CERVIX, PROSTATE, BREAST, COLON — screen by organ, not gender
  ageMinMonths    Int? // Minimum age to begin (null = any age)
  ageMaxMonths    Int? // Maximum age to offer (null = no upper limit)
  frequency       String? // "annually", "every 3 years", "once at 18 months", etc.
  conditions      String?  @db.NVarChar(Max) // JSON: additional conditions that trigger this screening
  replacedById    String? // Self-reference: PHQ-A replaces PHQ-9 for adolescents
  evidenceSource  String? // "USPSTF 2023", "ACS", "AAP Bright Futures"
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  replacedBy   ScreeningProtocol?  @relation("ScreeningReplacement", fields: [replacedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replacements ScreeningProtocol[] @relation("ScreeningReplacement")

  @@index([organRequired])
  @@index([ageMinMonths, ageMaxMonths])
  @@index([isActive])
}

// ============== CLINIC ENVIRONMENTS (Subspecialty) ==============
// Configures the portal experience per specialty context.
// When a user selects "Dermatology" vs "Pediatrics", the dashboard,
// AI prompts, COMPASS questions, and chart layout all change.

model ClinicEnvironment {
  id             String  @id @default(cuid())
  organizationId String
  name           String // "Riverdale Dermatology", "Downtown Pediatrics"
  specialtyCode  String // DERM, CARDS, PEDS, URO, PCP, NEURO, ORTHO, ENDO, GI, PULM, RHEUM, PSYCH, ONC, OBGYN
  description    String?
  isDefault      Boolean @default(false) // Default env for the org

  // Configuration (JSON)
  dashboardConfig   String? @db.NVarChar(Max) // Widgets, layout, priority panels
  compassOverrides  String? @db.NVarChar(Max) // Extra COMPASS questions, specialty-specific flows
  aiPromptOverrides String? @db.NVarChar(Max) // Specialty-tuned AI differential prompts
  chartLayoutConfig String? @db.NVarChar(Max) // Which chart sections to promote/hide/reorder
  orderingDefaults  String? @db.NVarChar(Max) // Default lab panels, imaging protocols per specialty

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userSessions UserEnvironmentSession[]

  @@unique([organizationId, specialtyCode])
  @@index([specialtyCode])
  @@index([isActive])
}

// Tracks which environment a user is currently working in.
model UserEnvironmentSession {
  id            String   @id @default(cuid())
  userId        String
  environmentId String
  startedAt     DateTime @default(now())
  lastActiveAt  DateTime @default(now())

  user        User              @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  environment ClinicEnvironment @relation(fields: [environmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId]) // One active environment per user
  @@index([environmentId])
}

// ============== CLINICAL IMAGES (Visual AI) ==============
// Patient-submitted or provider-captured clinical images.
// Supports the body-map + multi-view capture flow in COMPASS.

model ClinicalImage {
  id             String  @id @default(cuid())
  patientId      String
  organizationId String
  encounterId    String?
  assessmentId String?

  // Image metadata
  imageType     String // SKIN_LESION, WOUND, RASH, ORAL, EYE, EAR, GENERAL
  bodyRegion    String // HEAD, NECK, CHEST, ABDOMEN, ARM_L, ARM_R, HAND_L, HAND_R, LEG_L, LEG_R, FOOT_L, FOOT_R, BACK, FACE
  bodySubRegion String? // PALM, DORSUM, DIGITS, FOREARM, UPPER_ARM, etc.
  viewType      String // CLOSEUP, BODY_PART, WIDE_CONTEXT (3 standardized views)
  laterality    String? // LEFT, RIGHT, BILATERAL, MIDLINE

  // Storage
  storagePath   String // Encrypted blob storage path
  thumbnailPath String? // Compressed thumbnail for list views
  mimeType      String  @default("image/jpeg")
  fileSizeBytes Int?

  // Patient-provided context
  patientNotes  String?  @db.NVarChar(Max) // "It started 3 days ago and is spreading"
  durationDays  Int? // How long the patient has had this
  isProgressing Boolean? // Is it getting worse?

  // AI Analysis results (JSON)
  aiAnalysis     String? @db.NVarChar(Max) // Morphology, color, border, distribution, ABCDE score
  aiDifferential String? @db.NVarChar(Max) // AI-suggested diagnoses with confidence
  aiConfidence   Float? // Overall confidence 0-1
  aiModelVersion String? // Which model version produced the analysis

  // Provider review
  providerReview String?   @db.NVarChar(Max) // Provider's clinical assessment
  confirmedDx    String? // Confirmed diagnosis after provider review
  reviewedAt     DateTime?
  reviewedById   String?

  // Grouping (multiple images from same complaint form a set)
  imageSetId String? // Groups CLOSEUP + BODY_PART + WIDE_CONTEXT together

  isActive   Boolean  @default(true)
  capturedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  patient      Patient            @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  encounter    Encounter?         @relation(fields: [encounterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assessment   PatientAssessment? @relation(fields: [assessmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewedBy   User?              @relation(fields: [reviewedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([patientId])
  @@index([encounterId])
  @@index([assessmentId])
  @@index([imageSetId])
  @@index([imageType, bodyRegion])
  @@index([capturedAt])
  @@index([organizationId])
}

// ============== USAGE RECORDS (Billing) ==============

model UsageRecord {
  id             String   @id @default(cuid())
  organizationId String
  event          String
  day            String
  count          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([organizationId, event, day])
  @@index([organizationId])
  @@index([event])
  @@index([day])
}
